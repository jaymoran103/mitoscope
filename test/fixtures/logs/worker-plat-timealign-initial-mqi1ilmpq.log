{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015DnbcCksnRH1tUGWGtkh4x","type":"tool_result","content":"1\t// The game board served at /play/:id. The full puzzle (dates included) is\n2\t// inlined into the page; the client engine hides each date until the player\n3\t// commits, then reveals it with the snap/flash animations that are the\n4\t// emotional core of the game. Server-rendering the data avoids a loading flash\n5\t// and a round-trip — the /api/puzzles routes still expose the same contract.\n6\timport type { Puzzle } from \"./puzzles.js\";\n7\timport {\n8\t  AUTH_CHIP_SCRIPT,\n9\t  authChip,\n10\t  bodyHeader,\n11\t  escapeHtml,\n12\t  inlineJson,\n13\t  PAGE_CSS,\n14\t  pageHeader,\n15\t} from \"./ui.js\";\n16\t\n17\tconst DIFFICULTY_LABEL: Record<string, string> = {\n18\t  easy: \"Easy\",\n19\t  medium: \"Medium\",\n20\t  hard: \"Hard\",\n21\t};\n22\t\n23\texport function gameBoard({\n24\t  app,\n25\t  puzzle,\n26\t}: {\n27\t  app: string;\n28\t  puzzle: Puzzle;\n29\t}): string {\n30\t  const theme = puzzle.theme ?? \"Mixed events\";\n31\t  const difficulty = DIFFICULTY_LABEL[puzzle.difficulty] ?? puzzle.difficulty;\n32\t  const years = puzzle.events.map((e) => Number(e.date.slice(0, 4)));\n33\t  const span =\n34\t    years.length && Math.min(...years) !== Math.max(...years)\n35\t      ? `${Math.min(...years)}–${Math.max(...years)}`\n36\t      : String(years[0] ?? \"—\");\n37\t  const tags = [...new Set(puzzle.events.flatMap((e) => e.tags))];\n38\t  const metaBits = [\n39\t    difficulty,\n40\t    span,\n41\t    `${puzzle.events.length} events`,\n42\t    ...(tags.length ? [tags.join(\", \")] : []),\n43\t  ];\n44\t  const meta = metaBits.map((b) => escapeHtml(b)).join(\" · \");\n45\t  return `<!doctype html>\n46\t<html lang=\"en\">\n47\t<head>\n48\t<meta charset=\"utf-8\">\n49\t<meta name=\"viewport\" content=\"width=device-width,initial-scale=1,maximum-scale=1\">\n50\t<title>${escapeHtml(theme)} — ${escapeHtml(app)}</title>\n51\t<style>\n52\t${PAGE_CSS}\n53\t  body{padding-bottom:2rem}\n54\t  .board-wrap{padding-top:.2rem}\n55\t  .meta{margin:.1rem 0 .9rem;font-size:.92rem}\n56\t\n57\t  /* Progress — a thin neutral bar, black fill, no accent colour. */\n58\t  .progress{height:4px;background:var(--soft2);margin:.1rem 0 1.1rem}\n59\t  .progress > i{display:block;height:100%;width:0;background:#000;transition:width .4s ease}\n60\t\n61\t  /* The timeline lives in its own rectangular container, so its width stays\n62\t     constant however many cards it grows to hold. */\n63\t  .timeline{position:relative;border:1px solid var(--line);background:var(--bg);\n64\t            padding:.8rem 1rem .8rem 30px;margin:.2rem 0 1.1rem}\n65\t  .timeline::before{content:\"\";position:absolute;left:13px;top:30px;bottom:30px;width:2px;\n66\t                    background:var(--line)}\n67\t\n68\t  /* Direction-of-time caps so it's obvious which end is which. */\n69\t  .axis-cap{position:relative;height:22px;display:flex;align-items:center;\n70\t            font-size:.74rem;color:var(--fg)}\n71\t  .axis-cap .cap-arrow{position:absolute;left:-21px;width:11px;text-align:center;\n72\t                       font-size:1.05rem;line-height:1}\n73\t\n74\t  /* Insertion gaps — always visibly marked as drop targets, not hover-only. */\n75\t  .slot{position:relative;min-height:28px;margin:5px 0;cursor:pointer;\n76\t        border:1px dashed var(--line);background:transparent;display:flex;align-items:center;\n77\t        transition:min-height .18s ease,background .18s ease,border-color .18s ease}\n78\t  .slot::before{content:\"\";position:absolute;left:-21px;top:50%;transform:translateY(-50%);\n79\t                width:11px;height:11px;border-radius:50%;background:var(--bg);\n80\t                border:2px solid var(--line);transition:background .15s,border-color .15s}\n81\t  .slot::after{content:\"＋ Place here\";position:absolute;left:11px;top:50%;transform:translateY(-50%);\n82\t               font-size:.74rem;color:var(--fg);transition:color .15s}\n83\t  .slot:hover{background:var(--soft);border-color:var(--fg)}\n84\t  .slot:hover::before{background:var(--fg);border-color:var(--fg)}\n85\t  .slot:focus-visible{outline:2px solid var(--fg);outline-offset:2px}\n86\t  .slot.sel{min-height:46px;background:var(--soft);border-style:solid;border-color:var(--fg)}\n87\t  .slot.sel::before{background:var(--fg);border-color:var(--fg)}\n88\t  .slot.sel::after{content:\"Place here ✓\";font-weight:700}\n89\t  /* While a placement is being revealed the gaps don't respond — don't let them\n90\t     keep advertising themselves as clickable. */\n91\t  .timeline.locked .slot{cursor:default;border-color:transparent;background:transparent}\n92\t  .timeline.locked .slot::before{opacity:.35}\n93\t  .timeline.locked .slot::after{opacity:0}\n94\t  .timeline.locked .slot.sel{border-color:var(--fg)}\n95\t\n96\t  .card{position:relative;display:flex;gap:.7rem;align-items:center;background:var(--bg);\n97\t        border:1px solid var(--line2);padding:.6rem .75rem;margin:.1rem 0}\n98\t  .card .dot{position:absolute;left:-21px;top:50%;transform:translateY(-50%);width:11px;height:11px;\n99\t             border-radius:50%;background:var(--fg);border:2px solid var(--bg)}\n100\t  .card.correct .dot{background:var(--good)}\n101\t  .card.wrong .dot{background:var(--bad)}\n102\t  .thumb{width:44px;height:44px;flex:none;object-fit:cover;background:var(--soft);\n103\t         display:grid;place-items:center;font-weight:700;color:var(--fg);font-size:1.1rem;overflow:hidden}\n104\t  .thumb img{width:100%;height:100%;object-fit:cover}\n105\t  .card .body{min-width:0;flex:1}\n106\t  .card .ct{margin:0;font-size:.92rem;font-weight:700;line-height:1.25}\n107\t  .card .cd{font-size:.8rem;margin-top:.15rem}\n108\t  .card.correct .cd{color:var(--good)}\n109\t  .card.wrong .cd{color:var(--bad)}\n110\t  .card .badge{position:absolute;right:.7rem;top:-.62rem;font-size:.72rem;font-weight:700;\n111\t               padding:.08rem .45rem;background:var(--bg);border:1px solid var(--line);opacity:0}\n112\t  .card.anchor .badge{opacity:1}\n113\t  .card.just .badge{opacity:1}\n114\t  .card.correct.just .badge{color:var(--good);border-color:var(--good)}\n115\t  .card.wrong.just .badge{color:var(--bad);border-color:var(--bad)}\n116\t  .card.just{animation:pop .5s cubic-bezier(.2,1.3,.4,1)}\n117\t  @keyframes pop{0%{transform:scale(.7);opacity:0}60%{transform:scale(1.04)}100%{transform:scale(1);opacity:1}}\n118\t\n119\t  /* The deal tray — the current card to place. */\n120\t  .tray{position:sticky;bottom:0;z-index:20;margin-top:1rem;background:var(--bg)}\n121\t  .tray-inner{background:var(--bg);border:1px solid var(--line);padding:1rem}\n122\t  .deal{display:flex;gap:.9rem;align-items:flex-start}\n123\t  .deal .thumb{width:60px;height:60px;font-size:1.4rem}\n124\t  .deal .body{flex:1;min-width:0}\n125\t  .deal .hint{font-size:.74rem}\n126\t  .deal h2{font-family:var(--title);border:0;padding:0;margin:.1rem 0 .25rem;font-size:1.1rem;line-height:1.25}\n127\t  .deal p{margin:0;font-size:.9rem}\n128\t  .commit{display:flex;gap:.6rem;align-items:center;margin-top:.85rem}\n129\t  .commit .pick{flex:1;font-size:.86rem}\n130\t  .btn{background:var(--soft);color:var(--fg);border:1px solid var(--line);\n131\t       padding:.5rem 1.2rem;font-weight:700;font-size:.92rem;cursor:pointer;\n132\t       font-family:inherit;text-decoration:none;display:inline-block}\n133\t  .btn:hover:not(:disabled){background:var(--soft2);border-color:var(--fg);text-decoration:none}\n134\t  .btn.primary{border-color:var(--fg)}\n135\t  .btn:disabled{color:var(--muted);cursor:not-allowed}\n136\t  .float{position:fixed;left:50%;transform:translateX(-50%);z-index:40;font-weight:800;\n137\t         pointer-events:none;animation:rise 1s ease forwards}\n138\t  @keyframes rise{0%{opacity:0;transform:translate(-50%,10px) scale(.8)}\n139\t                  20%{opacity:1}100%{opacity:0;transform:translate(-50%,-46px) scale(1.1)}}\n140\t\n141\t  /* Results. */\n142\t  .results{text-align:center;padding:1.2rem 0 .8rem}\n143\t  .results .restitle{font-family:var(--title);font-size:1rem}\n144\t  .results .grade{font-family:var(--title);font-size:2.2rem;margin:.15rem 0}\n145\t  .results .acc b{font-weight:700}\n146\t  .reslist{margin:1.3rem 0;text-align:left;border:1px solid var(--line)}\n147\t  .resrow{display:flex;gap:.7rem;align-items:center;padding:.55rem .8rem;border-bottom:1px solid var(--line2)}\n148\t  .resrow:last-child{border-bottom:0}\n149\t  .resrow .mk{font-size:1rem}\n150\t  .resrow .rt{flex:1;min-width:0}\n151\t  .resrow .rt .n{font-size:.92rem;font-weight:700}\n152\t  .resrow .rt .d{font-size:.78rem}\n153\t  .resrow a{font-size:.84rem;white-space:nowrap}\n154\t  .actions{display:flex;gap:.7rem;justify-content:center;flex-wrap:wrap;margin-top:1.3rem}\n155\t</style>\n156\t</head>\n157\t<body>\n158\t${pageHeader({ back: true })}\n159\t${bodyHeader({\n160\t  left: `<span id=\"sub\">${puzzle.events.length} events to place</span>`,\n161\t  right: `<span id=\"stats\">Score&nbsp;<b id=\"score\">0</b> · Streak&nbsp;<b id=\"streak\">0</b></span>${authChip()}`,\n162\t})}\n163\t\n164\t<main class=\"wrap board-wrap\">\n165\t  <h1>${escapeHtml(theme)}</h1>\n166\t  <p class=\"meta\">${meta}</p>\n167\t  <div class=\"progress\"><i id=\"bar\"></i></div>\n168\t  <div id=\"board\" aria-live=\"polite\"></div>\n169\t</main>\n170\t\n171\t<script id=\"puzzle\" type=\"application/json\">${inlineJson(puzzle)}</script>\n172\t<script>\n173\t${AUTH_CHIP_SCRIPT}\n174\t</script>\n175\t<script>\n176\t${ENGINE}\n177\t</script>\n178\t</body>\n179\t</html>`;\n180\t}\n181\t\n182\t// The client engine is a single template string so it ships verbatim with no\n183\t// bundler. It is plain ES2020 — no framework, no dependencies.\n184\tconst ENGINE = String.raw`\n185\t(function(){\n186\t  \"use strict\";\n187\t  var puzzle = JSON.parse(document.getElementById('puzzle').textContent);\n188\t  var board = document.getElementById('board');\n189\t  var elScore = document.getElementById('score');\n190\t  var elStreak = document.getElementById('streak');\n191\t  var elStreakBox = elStreak.parentElement;\n192\t  var elBar = document.getElementById('bar');\n193\t  var elSub = document.getElementById('sub');\n194\t\n195\t  var POINTS = 100, STREAK_BONUS = 25;\n196\t\n197\t  // ---- helpers ----------------------------------------------------------\n198\t  function shuffle(a){ a = a.slice(); for(var i=a.length-1;i>0;i--){var j=Math.floor(Math.random()*(i+1));var t=a[i];a[i]=a[j];a[j]=t;} return a; }\n199\t  function byDate(a,b){ return a.date < b.date ? -1 : a.date > b.date ? 1 : 0; }\n200\t  function esc(s){ return String(s).replace(/[&<>\"']/g,function(c){return({'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;',\"'\":'&#39;'})[c];}); }\n201\t  function titleFromUrl(u){ try{ var p=u.split('/wiki/')[1]; return decodeURIComponent(p); }catch(e){ return null; } }\n202\t  function initials(t){ var m=t.replace(/^[^A-Za-z0-9]+/,'').match(/[A-Za-z0-9]/); return m?m[0].toUpperCase():'?'; }\n203\t\n204\t  // ---- image prefetch (progressive enhancement) -------------------------\n205\t  // Use the event's imageUrl if authored, else lazily resolve a thumbnail from\n206\t  // the Wikipedia REST summary endpoint. Failures fall back to a typographic\n207\t  // tile, so the game never depends on the network.\n208\t  var imageCache = {};\n209\t  function loadImage(ev){\n210\t    if (imageCache[ev.id] !== undefined) return Promise.resolve(imageCache[ev.id]);\n211\t    if (ev.imageUrl){ imageCache[ev.id]=ev.imageUrl; return Promise.resolve(ev.imageUrl); }\n212\t    var title = titleFromUrl(ev.wikipediaUrl);\n213\t    if (!title){ imageCache[ev.id]=null; return Promise.resolve(null); }\n214\t    var api = 'https://en.wikipedia.org/api/rest_v1/page/summary/' + encodeURIComponent(title);\n215\t    return fetch(api).then(function(r){ return r.ok ? r.json() : null; }).then(function(d){\n216\t      var src = d && d.thumbnail && d.thumbnail.source ? d.thumbnail.source : null;\n217\t      imageCache[ev.id] = src; return src;\n218\t    }).catch(function(){ imageCache[ev.id]=null; return null; });\n219\t  }\n220\t  function paintThumb(el, ev){\n221\t    el.textContent = initials(ev.title);\n222\t    loadImage(ev).then(function(src){\n223\t      if(!src) return;\n224\t      var img = new Image();\n225\t      img.alt = '';\n226\t      img.onload = function(){ el.textContent=''; el.appendChild(img); };\n227\t      img.src = src;\n228\t    });\n229\t  }\n230\t\n231\t  // ---- game state -------------------------------------------------------\n232\t  var state;\n233\t  function newGame(){\n234\t    var all = shuffle(puzzle.events);\n235\t    var chrono = all.slice().sort(byDate);\n236\t    var anchor = chrono[Math.floor(chrono.length/2)]; // chronologically middle\n237\t    var queue = shuffle(all.filter(function(e){ return e.id !== anchor.id; }));\n238\t    state = {\n239\t      placed: [Object.assign({}, anchor, {status:'anchor'})],\n240\t      queue: queue,\n241\t      total: queue.length,\n242\t      sel: null,\n243\t      score: 0,\n244\t      streak: 0,\n245\t      correct: 0,\n246\t      done: 0,\n247\t      locked: false,\n248\t      justId: null\n249\t    };\n250\t    // warm the cache so thumbnails are ready when a card surfaces\n251\t    puzzle.events.forEach(loadImage);\n252\t    render();\n253\t  }\n254\t\n255\t  function correctIndex(ev){\n256\t    var i = 0;\n257\t    while (i < state.placed.length && state.placed[i].date < ev.date) i++;\n258\t    return i;\n259\t  }\n260\t\n261\t  // ---- rendering --------------------------------------------------------\n262\t  function cardHtml(ev, cls){\n263\t    var dateLine = ev.status==='hidden' ? '' :\n264\t      '<div class=\"cd\">'+esc(ev.displayDate)+'</div>';\n265\t    var badge = '';\n266\t    if (ev.status==='anchor') badge='<span class=\"badge\">Anchor</span>';\n267\t    else if (ev.id===state.justId) badge='<span class=\"badge\">'+(ev.status==='correct'?'correct':'actually here')+'</span>';\n268\t    return '<div class=\"card '+cls+'\" data-ev=\"'+esc(ev.id)+'\">'+\n269\t      '<span class=\"dot\"></span>'+\n270\t      '<span class=\"thumb\" data-thumb=\"'+esc(ev.id)+'\"></span>'+\n271\t      '<div class=\"body\"><p class=\"ct\">'+esc(ev.title)+'</p>'+dateLine+'</div>'+\n272\t      badge+'</div>';\n273\t  }\n274\t\n275\t  function render(){\n276\t    if (state.queue.length===0 && !state.current){ return renderResults(); }\n277\t    if (!state.current) state.current = state.queue.shift();\n278\t    state.placed.sort(byDate);\n279\t\n280\t    elSub.textContent = (state.done+1)+' of '+(state.total)+' to place';\n281\t    elBar.style.width = Math.round((state.done/state.total)*100)+'%';\n282\t\n283\t    var html = '<div class=\"timeline'+(state.locked?' locked':'')+'\" id=\"tl\">';\n284\t    html += '<div class=\"axis-cap top\"><span class=\"cap-arrow\" aria-hidden=\"true\">↑</span>Earlier in time</div>';\n285\t    for (var i=0;i<=state.placed.length;i++){\n286\t      html += '<div class=\"slot'+(state.sel===i?' sel':'')+'\" data-slot=\"'+i+'\" role=\"button\" tabindex=\"0\" aria-label=\"Place event in position '+(i+1)+' of '+(state.placed.length+1)+'\"></div>';\n287\t      if (i < state.placed.length){\n288\t        var ev = state.placed[i];\n289\t        var cls = (ev.status||'') + (ev.id===state.justId?' just':'');\n290\t        html += cardHtml(ev, cls.trim());\n291\t      }\n292\t    }\n293\t    html += '<div class=\"axis-cap bottom\"><span class=\"cap-arrow\" aria-hidden=\"true\">↓</span>Later in time</div>';\n294\t    html += '</div>';\n295\t\n296\t    var cur = state.current;\n297\t    html += '<div class=\"tray\"><div class=\"tray-inner\">'+\n298\t      '<div class=\"deal\">'+\n299\t        '<span class=\"thumb\" data-thumb=\"'+esc(cur.id)+'\"></span>'+\n300\t        '<div class=\"body\"><div class=\"hint\">Where does this go?</div>'+\n301\t          '<h2>'+esc(cur.title)+'</h2><p>'+esc(cur.summary)+'</p></div>'+\n302\t      '</div>'+\n303\t      '<div class=\"commit\">'+\n304\t        '<div class=\"pick\" id=\"pick\">'+(state.sel===null?'Tap a marked gap on the timeline ↑':'Gap chosen — <b>commit to reveal</b>')+'</div>'+\n305\t        '<button class=\"btn primary\" id=\"commit\"'+(state.sel===null?' disabled':'')+'>Commit</button>'+\n306\t      '</div>'+\n307\t    '</div></div>';\n308\t\n309\t    board.innerHTML = html;\n310\t    // thumbnails\n311\t    board.querySelectorAll('[data-thumb]').forEach(function(el){\n312\t      var id = el.getAttribute('data-thumb');\n313\t      var ev = (id===cur.id) ? cur : state.placed.filter(function(e){return e.id===id;})[0];\n314\t      if (ev) paintThumb(el, ev);\n315\t    });\n316\t    wire();\n317\t  }\n318\t\n319\t  function wire(){\n320\t    board.querySelectorAll('.slot').forEach(function(s){\n321\t      var idx = parseInt(s.getAttribute('data-slot'),10);\n322\t      var choose = function(){ if(state.locked) return; state.sel = idx; render(); };\n323\t      s.addEventListener('click', choose);\n324\t      s.addEventListener('keydown', function(e){ if(e.key==='Enter'||e.key===' '){ e.preventDefault(); choose(); } });\n325\t    });\n326\t    var c = document.getElementById('commit');\n327\t    if (c) c.addEventListener('click', commit);\n328\t  }\n329\t\n330\t  function commit(){\n331\t    if (state.locked || state.sel===null) return;\n332\t    state.locked = true;\n333\t    var cur = state.current;\n334\t    var want = correctIndex(cur);\n335\t    var ok = state.sel === want;\n336\t\n337\t    var gained = 0;\n338\t    if (ok){ gained = POINTS + STREAK_BONUS*state.streak; state.streak++; state.correct++; }\n339\t    else { state.streak = 0; }\n340\t    state.score += gained;\n341\t\n342\t    // Insert at the CORRECT index either way — the timeline stays valid; a wrong\n343\t    // guess simply snaps to where it belongs.\n344\t    cur.status = ok ? 'correct' : 'wrong';\n345\t    state.placed.push(cur);\n346\t    state.placed.sort(byDate);\n347\t    state.justId = cur.id;\n348\t    state.done++;\n349\t    state.sel = null;\n350\t    state.current = null;\n351\t\n352\t    updateStats(gained, ok);\n353\t    render();\n354\t    // clear the \"just placed\" emphasis after the animation, then advance\n355\t    setTimeout(function(){ state.justId = null; state.locked = false; render(); }, 1050);\n356\t  }\n357\t\n358\t  function updateStats(gained, ok){\n359\t    elScore.textContent = state.score;\n360\t    elStreak.textContent = state.streak;\n361\t    if (state.streak>0) elStreakBox.classList.remove('cold'); else elStreakBox.classList.add('cold');\n362\t    if (gained>0) floatText('+'+gained, 'var(--good)');\n363\t    else floatText(ok?'+0':'missed', 'var(--bad)');\n364\t  }\n365\t\n366\t  function floatText(txt, color){\n367\t    var f = document.createElement('div');\n368\t    f.className='float'; f.textContent=txt; f.style.color=color; f.style.top='64px'; f.style.fontSize='1.3rem';\n369\t    document.body.appendChild(f);\n370\t    setTimeout(function(){ f.remove(); }, 1000);\n371\t  }\n372\t\n373\t  // ---- results ----------------------------------------------------------\n374\t  function renderResults(){\n375\t    elBar.style.width='100%';\n376\t    elSub.textContent='Complete';\n377\t    var chrono = state.placed.slice().sort(byDate);\n378\t    var acc = state.correct + ' / ' + state.total;\n379\t    var pct = Math.round((state.correct/state.total)*100);\n380\t    var grade = pct===100?'Perfect!':pct>=80?'Sharp eye':pct>=50?'Not bad':'Keep going';\n381\t\n382\t    var rows = chrono.map(function(ev){\n383\t      var mk = ev.status==='wrong' ? '✕' : '✓';\n384\t      var col = ev.status==='wrong' ? 'var(--bad)' : (ev.status==='anchor'?'#000':'var(--good)');\n385\t      return '<div class=\"resrow\">'+\n386\t        '<span class=\"mk\" style=\"color:'+col+'\">'+mk+'</span>'+\n387\t        '<div class=\"rt\"><div class=\"n\">'+esc(ev.title)+'</div><div class=\"d\">'+esc(ev.displayDate)+'</div></div>'+\n388\t        '<a href=\"'+esc(ev.wikipediaUrl)+'\" target=\"_blank\" rel=\"noopener\">Dive deeper ↗</a>'+\n389\t      '</div>';\n390\t    }).join('');\n391\t\n392\t    board.innerHTML =\n393\t      '<div class=\"results\">'+\n394\t        '<div class=\"restitle\">'+esc(puzzle.theme||'Results')+'</div>'+\n395\t        '<div class=\"grade\">'+esc(grade)+'</div>'+\n396\t        '<div class=\"acc\">You placed <b>'+acc+'</b> correctly · <b>'+state.score+'</b> points</div>'+\n397\t      '</div>'+\n398\t      '<div class=\"reslist\">'+rows+'</div>'+\n399\t      '<div class=\"actions\">'+\n400\t        '<button class=\"btn primary\" id=\"again\">Play again</button>'+\n401\t        '<a class=\"btn\" href=\"/\">More puzzles</a>'+\n402\t      '</div>';\n403\t    var a = document.getElementById('again');\n404\t    if (a) a.addEventListener('click', function(){ newGame(); window.scrollTo(0,0); });\n405\t  }\n406\t\n407\t  newGame();\n408\t})();\n409\t`;\n410\t"}]},"parent_tool_use_id":null,"session_id":"ea97c4a2-67f7-4ff7-8c74-f9bccb4cced2","uuid":"b8b1578c-1f6c-4d38-a104-c7a334ea87e8","timestamp":"2026-06-17T12:34:45.183Z","tool_use_result":{"type":"text","file":{"filePath":"/data/work/worker-plat-timealign-initial-mqi1ilmpq/src/game.ts","content":"// The game board served at /play/:id. The full puzzle (dates included) is\n// inlined into the page; the client engine hides each date until the player\n// commits, then reveals it with the snap/flash animations that are the\n// emotional core of the game. Server-rendering the data avoids a loading flash\n// and a round-trip — the /api/puzzles routes still expose the same contract.\nimport type { Puzzle } from \"./puzzles.js\";\nimport {\n  AUTH_CHIP_SCRIPT,\n  authChip,\n  bodyHeader,\n  escapeHtml,\n  inlineJson,\n  PAGE_CSS,\n  pageHeader,\n} from \"./ui.js\";\n\nconst DIFFICULTY_LABEL: Record<string, string> = {\n  easy: \"Easy\",\n  medium: \"Medium\",\n  hard: \"Hard\",\n};\n\nexport function gameBoard({\n  app,\n  puzzle,\n}: {\n  app: string;\n  puzzle: Puzzle;\n}): string {\n  const theme = puzzle.theme ?? \"Mixed events\";\n  const difficulty = DIFFICULTY_LABEL[puzzle.difficulty] ?? puzzle.difficulty;\n  const years = puzzle.events.map((e) => Number(e.date.slice(0, 4)));\n  const span =\n    years.length && Math.min(...years) !== Math.max(...years)\n      ? `${Math.min(...years)}–${Math.max(...years)}`\n      : String(years[0] ?? \"—\");\n  const tags = [...new Set(puzzle.events.flatMap((e) => e.tags))];\n  const metaBits = [\n    difficulty,\n    span,\n    `${puzzle.events.length} events`,\n    ...(tags.length ? [tags.join(\", \")] : []),\n  ];\n  const meta = metaBits.map((b) => escapeHtml(b)).join(\" · \");\n  return `<!doctype html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1,maximum-scale=1\">\n<title>${escapeHtml(theme)} — ${escapeHtml(app)}</title>\n<style>\n${PAGE_CSS}\n  body{padding-bottom:2rem}\n  .board-wrap{padding-top:.2rem}\n  .meta{margin:.1rem 0 .9rem;font-size:.92rem}\n\n  /* Progress — a thin neutral bar, black fill, no accent colour. */\n  .progress{height:4px;background:var(--soft2);margin:.1rem 0 1.1rem}\n  .progress > i{display:block;height:100%;width:0;background:#000;transition:width .4s ease}\n\n  /* The timeline lives in its own rectangular container, so its width stays\n     constant however many cards it grows to hold. */\n  .timeline{position:relative;border:1px solid var(--line);background:var(--bg);\n            padding:.8rem 1rem .8rem 30px;margin:.2rem 0 1.1rem}\n  .timeline::before{content:\"\";position:absolute;left:13px;top:30px;bottom:30px;width:2px;\n                    background:var(--line)}\n\n  /* Direction-of-time caps so it's obvious which end is which. */\n  .axis-cap{position:relative;height:22px;display:flex;align-items:center;\n            font-size:.74rem;color:var(--fg)}\n  .axis-cap .cap-arrow{position:absolute;left:-21px;width:11px;text-align:center;\n                       font-size:1.05rem;line-height:1}\n\n  /* Insertion gaps — always visibly marked as drop targets, not hover-only. */\n  .slot{position:relative;min-height:28px;margin:5px 0;cursor:pointer;\n        border:1px dashed var(--line);background:transparent;display:flex;align-items:center;\n        transition:min-height .18s ease,background .18s ease,border-color .18s ease}\n  .slot::before{content:\"\";position:absolute;left:-21px;top:50%;transform:translateY(-50%);\n                width:11px;height:11px;border-radius:50%;background:var(--bg);\n                border:2px solid var(--line);transition:background .15s,border-color .15s}\n  .slot::after{content:\"＋ Place here\";position:absolute;left:11px;top:50%;transform:translateY(-50%);\n               font-size:.74rem;color:var(--fg);transition:color .15s}\n  .slot:hover{background:var(--soft);border-color:var(--fg)}\n  .slot:hover::before{background:var(--fg);border-color:var(--fg)}\n  .slot:focus-visible{outline:2px solid var(--fg);outline-offset:2px}\n  .slot.sel{min-height:46px;background:var(--soft);border-style:solid;border-color:var(--fg)}\n  .slot.sel::before{background:var(--fg);border-color:var(--fg)}\n  .slot.sel::after{content:\"Place here ✓\";font-weight:700}\n  /* While a placement is being revealed the gaps don't respond — don't let them\n     keep advertising themselves as clickable. */\n  .timeline.locked .slot{cursor:default;border-color:transparent;background:transparent}\n  .timeline.locked .slot::before{opacity:.35}\n  .timeline.locked .slot::after{opacity:0}\n  .timeline.locked .slot.sel{border-color:var(--fg)}\n\n  .card{position:relative;display:flex;gap:.7rem;align-items:center;background:var(--bg);\n        border:1px solid var(--line2);padding:.6rem .75rem;margin:.1rem 0}\n  .card .dot{position:absolute;left:-21px;top:50%;transform:translateY(-50%);width:11px;height:11px;\n             border-radius:50%;background:var(--fg);border:2px solid var(--bg)}\n  .card.correct .dot{background:var(--good)}\n  .card.wrong .dot{background:var(--bad)}\n  .thumb{width:44px;height:44px;flex:none;object-fit:cover;background:var(--soft);\n         display:grid;place-items:center;font-weight:700;color:var(--fg);font-size:1.1rem;overflow:hidden}\n  .thumb img{width:100%;height:100%;object-fit:cover}\n  .card .body{min-width:0;flex:1}\n  .card .ct{margin:0;font-size:.92rem;font-weight:700;line-height:1.25}\n  .card .cd{font-size:.8rem;margin-top:.15rem}\n  .card.correct .cd{color:var(--good)}\n  .card.wrong .cd{color:var(--bad)}\n  .card .badge{position:absolute;right:.7rem;top:-.62rem;font-size:.72rem;font-weight:700;\n               padding:.08rem .45rem;background:var(--bg);border:1px solid var(--line);opacity:0}\n  .card.anchor .badge{opacity:1}\n  .card.just .badge{opacity:1}\n  .card.correct.just .badge{color:var(--good);border-color:var(--good)}\n  .card.wrong.just .badge{color:var(--bad);border-color:var(--bad)}\n  .card.just{animation:pop .5s cubic-bezier(.2,1.3,.4,1)}\n  @keyframes pop{0%{transform:scale(.7);opacity:0}60%{transform:scale(1.04)}100%{transform:scale(1);opacity:1}}\n\n  /* The deal tray — the current card to place. */\n  .tray{position:sticky;bottom:0;z-index:20;margin-top:1rem;background:var(--bg)}\n  .tray-inner{background:var(--bg);border:1px solid var(--line);padding:1rem}\n  .deal{display:flex;gap:.9rem;align-items:flex-start}\n  .deal .thumb{width:60px;height:60px;font-size:1.4rem}\n  .deal .body{flex:1;min-width:0}\n  .deal .hint{font-size:.74rem}\n  .deal h2{font-family:var(--title);border:0;padding:0;margin:.1rem 0 .25rem;font-size:1.1rem;line-height:1.25}\n  .deal p{margin:0;font-size:.9rem}\n  .commit{display:flex;gap:.6rem;align-items:center;margin-top:.85rem}\n  .commit .pick{flex:1;font-size:.86rem}\n  .btn{background:var(--soft);color:var(--fg);border:1px solid var(--line);\n       padding:.5rem 1.2rem;font-weight:700;font-size:.92rem;cursor:pointer;\n       font-family:inherit;text-decoration:none;display:inline-block}\n  .btn:hover:not(:disabled){background:var(--soft2);border-color:var(--fg);text-decoration:none}\n  .btn.primary{border-color:var(--fg)}\n  .btn:disabled{color:var(--muted);cursor:not-allowed}\n  .float{position:fixed;left:50%;transform:translateX(-50%);z-index:40;font-weight:800;\n         pointer-events:none;animation:rise 1s ease forwards}\n  @keyframes rise{0%{opacity:0;transform:translate(-50%,10px) scale(.8)}\n                  20%{opacity:1}100%{opacity:0;transform:translate(-50%,-46px) scale(1.1)}}\n\n  /* Results. */\n  .results{text-align:center;padding:1.2rem 0 .8rem}\n  .results .restitle{font-family:var(--title);font-size:1rem}\n  .results .grade{font-family:var(--title);font-size:2.2rem;margin:.15rem 0}\n  .results .acc b{font-weight:700}\n  .reslist{margin:1.3rem 0;text-align:left;border:1px solid var(--line)}\n  .resrow{display:flex;gap:.7rem;align-items:center;padding:.55rem .8rem;border-bottom:1px solid var(--line2)}\n  .resrow:last-child{border-bottom:0}\n  .resrow .mk{font-size:1rem}\n  .resrow .rt{flex:1;min-width:0}\n  .resrow .rt .n{font-size:.92rem;font-weight:700}\n  .resrow .rt .d{font-size:.78rem}\n  .resrow a{font-size:.84rem;white-space:nowrap}\n  .actions{display:flex;gap:.7rem;justify-content:center;flex-wrap:wrap;margin-top:1.3rem}\n</style>\n</head>\n<body>\n${pageHeader({ back: true })}\n${bodyHeader({\n  left: `<span id=\"sub\">${puzzle.events.length} events to place</span>`,\n  right: `<span id=\"stats\">Score&nbsp;<b id=\"score\">0</b> · Streak&nbsp;<b id=\"streak\">0</b></span>${authChip()}`,\n})}\n\n<main class=\"wrap board-wrap\">\n  <h1>${escapeHtml(theme)}</h1>\n  <p class=\"meta\">${meta}</p>\n  <div class=\"progress\"><i id=\"bar\"></i></div>\n  <div id=\"board\" aria-live=\"polite\"></div>\n</main>\n\n<script id=\"puzzle\" type=\"application/json\">${inlineJson(puzzle)}</script>\n<script>\n${AUTH_CHIP_SCRIPT}\n</script>\n<script>\n${ENGINE}\n</script>\n</body>\n</html>`;\n}\n\n// The client engine is a single template string so it ships verbatim with no\n// bundler. It is plain ES2020 — no framework, no dependencies.\nconst ENGINE = String.raw`\n(function(){\n  \"use strict\";\n  var puzzle = JSON.parse(document.getElementById('puzzle').textContent);\n  var board = document.getElementById('board');\n  var elScore = document.getElementById('score');\n  var elStreak = document.getElementById('streak');\n  var elStreakBox = elStreak.parentElement;\n  var elBar = document.getElementById('bar');\n  var elSub = document.getElementById('sub');\n\n  var POINTS = 100, STREAK_BONUS = 25;\n\n  // ---- helpers ----------------------------------------------------------\n  function shuffle(a){ a = a.slice(); for(var i=a.length-1;i>0;i--){var j=Math.floor(Math.random()*(i+1));var t=a[i];a[i]=a[j];a[j]=t;} return a; }\n  function byDate(a,b){ return a.date < b.date ? -1 : a.date > b.date ? 1 : 0; }\n  function esc(s){ return String(s).replace(/[&<>\"']/g,function(c){return({'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;',\"'\":'&#39;'})[c];}); }\n  function titleFromUrl(u){ try{ var p=u.split('/wiki/')[1]; return decodeURIComponent(p); }catch(e){ return null; } }\n  function initials(t){ var m=t.replace(/^[^A-Za-z0-9]+/,'').match(/[A-Za-z0-9]/); return m?m[0].toUpperCase():'?'; }\n\n  // ---- image prefetch (progressive enhancement) -------------------------\n  // Use the event's imageUrl if authored, else lazily resolve a thumbnail from\n  // the Wikipedia REST summary endpoint. Failures fall back to a typographic\n  // tile, so the game never depends on the network.\n  var imageCache = {};\n  function loadImage(ev){\n    if (imageCache[ev.id] !== undefined) return Promise.resolve(imageCache[ev.id]);\n    if (ev.imageUrl){ imageCache[ev.id]=ev.imageUrl; return Promise.resolve(ev.imageUrl); }\n    var title = titleFromUrl(ev.wikipediaUrl);\n    if (!title){ imageCache[ev.id]=null; return Promise.resolve(null); }\n    var api = 'https://en.wikipedia.org/api/rest_v1/page/summary/' + encodeURIComponent(title);\n    return fetch(api).then(function(r){ return r.ok ? r.json() : null; }).then(function(d){\n      var src = d && d.thumbnail && d.thumbnail.source ? d.thumbnail.source : null;\n      imageCache[ev.id] = src; return src;\n    }).catch(function(){ imageCache[ev.id]=null; return null; });\n  }\n  function paintThumb(el, ev){\n    el.textContent = initials(ev.title);\n    loadImage(ev).then(function(src){\n      if(!src) return;\n      var img = new Image();\n      img.alt = '';\n      img.onload = function(){ el.textContent=''; el.appendChild(img); };\n      img.src = src;\n    });\n  }\n\n  // ---- game state -------------------------------------------------------\n  var state;\n  function newGame(){\n    var all = shuffle(puzzle.events);\n    var chrono = all.slice().sort(byDate);\n    var anchor = chrono[Math.floor(chrono.length/2)]; // chronologically middle\n    var queue = shuffle(all.filter(function(e){ return e.id !== anchor.id; }));\n    state = {\n      placed: [Object.assign({}, anchor, {status:'anchor'})],\n      queue: queue,\n      total: queue.length,\n      sel: null,\n      score: 0,\n      streak: 0,\n      correct: 0,\n      done: 0,\n      locked: false,\n      justId: null\n    };\n    // warm the cache so thumbnails are ready when a card surfaces\n    puzzle.events.forEach(loadImage);\n    render();\n  }\n\n  function correctIndex(ev){\n    var i = 0;\n    while (i < state.placed.length && state.placed[i].date < ev.date) i++;\n    return i;\n  }\n\n  // ---- rendering --------------------------------------------------------\n  function cardHtml(ev, cls){\n    var dateLine = ev.status==='hidden' ? '' :\n      '<div class=\"cd\">'+esc(ev.displayDate)+'</div>';\n    var badge = '';\n    if (ev.status==='anchor') badge='<span class=\"badge\">Anchor</span>';\n    else if (ev.id===state.justId) badge='<span class=\"badge\">'+(ev.status==='correct'?'correct':'actually here')+'</span>';\n    return '<div class=\"card '+cls+'\" data-ev=\"'+esc(ev.id)+'\">'+\n      '<span class=\"dot\"></span>'+\n      '<span class=\"thumb\" data-thumb=\"'+esc(ev.id)+'\"></span>'+\n      '<div class=\"body\"><p class=\"ct\">'+esc(ev.title)+'</p>'+dateLine+'</div>'+\n      badge+'</div>';\n  }\n\n  function render(){\n    if (state.queue.length===0 && !state.current){ return renderResults(); }\n    if (!state.current) state.current = state.queue.shift();\n    state.placed.sort(byDate);\n\n    elSub.textContent = (state.done+1)+' of '+(state.total)+' to place';\n    elBar.style.width = Math.round((state.done/state.total)*100)+'%';\n\n    var html = '<div class=\"timeline'+(state.locked?' locked':'')+'\" id=\"tl\">';\n    html += '<div class=\"axis-cap top\"><span class=\"cap-arrow\" aria-hidden=\"true\">↑</span>Earlier in time</div>';\n    for (var i=0;i<=state.placed.length;i++){\n      html += '<div class=\"slot'+(state.sel===i?' sel':'')+'\" data-slot=\"'+i+'\" role=\"button\" tabindex=\"0\" aria-label=\"Place event in position '+(i+1)+' of '+(state.placed.length+1)+'\"></div>';\n      if (i < state.placed.length){\n        var ev = state.placed[i];\n        var cls = (ev.status||'') + (ev.id===state.justId?' just':'');\n        html += cardHtml(ev, cls.trim());\n      }\n    }\n    html += '<div class=\"axis-cap bottom\"><span class=\"cap-arrow\" aria-hidden=\"true\">↓</span>Later in time</div>';\n    html += '</div>';\n\n    var cur = state.current;\n    html += '<div class=\"tray\"><div class=\"tray-inner\">'+\n      '<div class=\"deal\">'+\n        '<span class=\"thumb\" data-thumb=\"'+esc(cur.id)+'\"></span>'+\n        '<div class=\"body\"><div class=\"hint\">Where does this go?</div>'+\n          '<h2>'+esc(cur.title)+'</h2><p>'+esc(cur.summary)+'</p></div>'+\n      '</div>'+\n      '<div class=\"commit\">'+\n        '<div class=\"pick\" id=\"pick\">'+(state.sel===null?'Tap a marked gap on the timeline ↑':'Gap chosen — <b>commit to reveal</b>')+'</div>'+\n        '<button class=\"btn primary\" id=\"commit\"'+(state.sel===null?' disabled':'')+'>Commit</button>'+\n      '</div>'+\n    '</div></div>';\n\n    board.innerHTML = html;\n    // thumbnails\n    board.querySelectorAll('[data-thumb]').forEach(function(el){\n      var id = el.getAttribute('data-thumb');\n      var ev = (id===cur.id) ? cur : state.placed.filter(function(e){return e.id===id;})[0];\n      if (ev) paintThumb(el, ev);\n    });\n    wire();\n  }\n\n  function wire(){\n    board.querySelectorAll('.slot').forEach(function(s){\n      var idx = parseInt(s.getAttribute('data-slot'),10);\n      var choose = function(){ if(state.locked) return; state.sel = idx; render(); };\n      s.addEventListener('click', choose);\n      s.addEventListener('keydown', function(e){ if(e.key==='Enter'||e.key===' '){ e.preventDefault(); choose(); } });\n    });\n    var c = document.getElementById('commit');\n    if (c) c.addEventListener('click', commit);\n  }\n\n  function commit(){\n    if (state.locked || state.sel===null) return;\n    state.locked = true;\n    var cur = state.current;\n    var want = correctIndex(cur);\n    var ok = state.sel === want;\n\n    var gained = 0;\n    if (ok){ gained = POINTS + STREAK_BONUS*state.streak; state.streak++; state.correct++; }\n    else { state.streak = 0; }\n    state.score += gained;\n\n    // Insert at the CORRECT index either way — the timeline stays valid; a wrong\n    // guess simply snaps to where it belongs.\n    cur.status = ok ? 'correct' : 'wrong';\n    state.placed.push(cur);\n    state.placed.sort(byDate);\n    state.justId = cur.id;\n    state.done++;\n    state.sel = null;\n    state.current = null;\n\n    updateStats(gained, ok);\n    render();\n    // clear the \"just placed\" emphasis after the animation, then advance\n    setTimeout(function(){ state.justId = null; state.locked = false; render(); }, 1050);\n  }\n\n  function updateStats(gained, ok){\n    elScore.textContent = state.score;\n    elStreak.textContent = state.streak;\n    if (state.streak>0) elStreakBox.classList.remove('cold'); else elStreakBox.classList.add('cold');\n    if (gained>0) floatText('+'+gained, 'var(--good)');\n    else floatText(ok?'+0':'missed', 'var(--bad)');\n  }\n\n  function floatText(txt, color){\n    var f = document.createElement('div');\n    f.className='float'; f.textContent=txt; f.style.color=color; f.style.top='64px'; f.style.fontSize='1.3rem';\n    document.body.appendChild(f);\n    setTimeout(function(){ f.remove(); }, 1000);\n  }\n\n  // ---- results ----------------------------------------------------------\n  function renderResults(){\n    elBar.style.width='100%';\n    elSub.textContent='Complete';\n    var chrono = state.placed.slice().sort(byDate);\n    var acc = state.correct + ' / ' + state.total;\n    var pct = Math.round((state.correct/state.total)*100);\n    var grade = pct===100?'Perfect!':pct>=80?'Sharp eye':pct>=50?'Not bad':'Keep going';\n\n    var rows = chrono.map(function(ev){\n      var mk = ev.status==='wrong' ? '✕' : '✓';\n      var col = ev.status==='wrong' ? 'var(--bad)' : (ev.status==='anchor'?'#000':'var(--good)');\n      return '<div class=\"resrow\">'+\n        '<span class=\"mk\" style=\"color:'+col+'\">'+mk+'</span>'+\n        '<div class=\"rt\"><div class=\"n\">'+esc(ev.title)+'</div><div class=\"d\">'+esc(ev.displayDate)+'</div></div>'+\n        '<a href=\"'+esc(ev.wikipediaUrl)+'\" target=\"_blank\" rel=\"noopener\">Dive deeper ↗</a>'+\n      '</div>';\n    }).join('');\n\n    board.innerHTML =\n      '<div class=\"results\">'+\n        '<div class=\"restitle\">'+esc(puzzle.theme||'Results')+'</div>'+\n        '<div class=\"grade\">'+esc(grade)+'</div>'+\n        '<div class=\"acc\">You placed <b>'+acc+'</b> correctly · <b>'+state.score+'</b> points</div>'+\n      '</div>'+\n      '<div class=\"reslist\">'+rows+'</div>'+\n      '<div class=\"actions\">'+\n        '<button class=\"btn primary\" id=\"again\">Play again</button>'+\n        '<a class=\"btn\" href=\"/\">More puzzles</a>'+\n      '</div>';\n    var a = document.getElementById('again');\n    if (a) a.addEventListener('click', function(){ newGame(); window.scrollTo(0,0); });\n  }\n\n  newGame();\n})();\n`;\n","numLines":410,"startLine":1,"totalLines":410}}}
