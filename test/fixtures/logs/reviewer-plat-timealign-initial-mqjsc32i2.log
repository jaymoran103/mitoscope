{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01W74xqUQ4uvoXBsxMrWjs3R","type":"tool_result","content":[{"type":"text","text":"{\"path\":\"src/game.ts\",\"ref\":\"agent/issue-6\",\"size\":25747,\"content\":\"// The game board served at /play/:id. The full puzzle (dates included) is\\n// inlined into the page; the client engine hides each date until the player\\n// commits, then reveals it with the snap/flash animations that are the\\n// emotional core of the game. Server-rendering the data avoids a loading flash\\n// and a round-trip — the /api/puzzles routes still expose the same contract.\\nimport type { Puzzle } from \\\"./puzzles.js\\\";\\nimport {\\n  AUTH_CHIP_SCRIPT,\\n  authChip,\\n  bodyHeader,\\n  escapeHtml,\\n  inlineJson,\\n  PAGE_CSS,\\n  pageHeader,\\n} from \\\"./ui.js\\\";\\n\\nconst DIFFICULTY_LABEL: Record<string, string> = {\\n  easy: \\\"Easy\\\",\\n  medium: \\\"Medium\\\",\\n  hard: \\\"Hard\\\",\\n};\\n\\nexport function gameBoard({\\n  app,\\n  puzzle,\\n}: {\\n  app: string;\\n  puzzle: Puzzle;\\n}): string {\\n  const theme = puzzle.theme ?? \\\"Mixed events\\\";\\n  const difficulty = DIFFICULTY_LABEL[puzzle.difficulty] ?? puzzle.difficulty;\\n  const years = puzzle.events.map((e) => Number(e.date.slice(0, 4)));\\n  const span =\\n    years.length && Math.min(...years) !== Math.max(...years)\\n      ? `${Math.min(...years)}–${Math.max(...years)}`\\n      : String(years[0] ?? \\\"—\\\");\\n  const tags = [...new Set(puzzle.events.flatMap((e) => e.tags))];\\n  const metaBits = [\\n    difficulty,\\n    span,\\n    `${puzzle.events.length} events`,\\n    ...(tags.length ? [tags.join(\\\", \\\")] : []),\\n  ];\\n  const meta = metaBits.map((b) => escapeHtml(b)).join(\\\" · \\\");\\n  return `<!doctype html>\\n<html lang=\\\"en\\\">\\n<head>\\n<meta charset=\\\"utf-8\\\">\\n<meta name=\\\"viewport\\\" content=\\\"width=device-width,initial-scale=1,maximum-scale=1\\\">\\n<title>${escapeHtml(theme)} — ${escapeHtml(app)}</title>\\n<style>\\n${PAGE_CSS}\\n  body{padding-bottom:2rem}\\n  .board-wrap{padding-top:.2rem}\\n  .meta{margin:.1rem 0 .6rem;font-size:.92rem}\\n\\n  /* Placement-mode switcher — a stark, monochrome segmented control. Lets\\n     testers swap between the three input prototypes; the choice persists. */\\n  .modes{display:flex;align-items:center;gap:.55rem;flex-wrap:wrap;margin:.2rem 0 .8rem}\\n  .modes-label{font-size:.84rem}\\n  .modeset{display:inline-flex;border:1px solid var(--line)}\\n  .modebtn{font-family:inherit;font-size:.84rem;background:var(--bg);color:var(--fg);\\n           border:0;border-left:1px solid var(--line);padding:.3rem .75rem;cursor:pointer;line-height:1.2}\\n  .modeset .modebtn:first-child{border-left:0}\\n  .modebtn:hover{background:var(--soft)}\\n  .modebtn[aria-selected=\\\"true\\\"]{background:#000;color:#fff;font-weight:700}\\n  .modebtn:focus-visible{outline:2px solid var(--fg);outline-offset:2px}\\n\\n  /* Progress — a thin neutral bar, black fill, no accent colour. */\\n  .progress{height:4px;background:var(--soft2);margin:.1rem 0 1.1rem}\\n  .progress > i{display:block;height:100%;width:0;background:#000;transition:width .4s ease}\\n\\n  /* The timeline lives in its own rectangular container, so its width stays\\n     constant however many cards it grows to hold. */\\n  .timeline{position:relative;border:1px solid var(--line);background:var(--bg);\\n            padding:.8rem 1rem .8rem 30px;margin:.2rem 0 1.1rem}\\n  .timeline::before{content:\\\"\\\";position:absolute;left:13px;top:30px;bottom:30px;width:2px;\\n                    background:var(--line)}\\n\\n  /* Direction-of-time caps so it's obvious which end is which. */\\n  .axis-cap{position:relative;height:22px;display:flex;align-items:center;\\n            font-size:.74rem;color:var(--fg)}\\n  .axis-cap .cap-arrow{position:absolute;left:-21px;width:11px;text-align:center;\\n                       font-size:1.05rem;line-height:1}\\n\\n  /* Insertion gaps — always visibly marked as drop targets, not hover-only. */\\n  .slot{position:relative;min-height:28px;margin:5px 0;cursor:pointer;\\n        border:1px dashed var(--line);background:transparent;display:flex;align-items:center;\\n        transition:min-height .18s ease,background .18s ease,border-color .18s ease}\\n  .slot::before{content:\\\"\\\";position:absolute;left:-21px;top:50%;transform:translateY(-50%);\\n                width:11px;height:11px;border-radius:50%;background:var(--bg);\\n                border:2px solid var(--line);transition:background .15s,border-color .15s}\\n  .slot::after{content:\\\"＋ Place here\\\";position:absolute;left:11px;top:50%;transform:translateY(-50%);\\n               font-size:.74rem;color:var(--fg);transition:color .15s}\\n  .slot:hover{background:var(--soft);border-color:var(--fg)}\\n  .slot:hover::before{background:var(--fg);border-color:var(--fg)}\\n  .slot:focus-visible{outline:2px solid var(--fg);outline-offset:2px}\\n  .slot.sel{min-height:46px;background:var(--soft);border-style:solid;border-color:var(--fg)}\\n  .slot.sel::before{background:var(--fg);border-color:var(--fg)}\\n  .slot.sel::after{content:\\\"Place here ✓\\\";font-weight:700}\\n  /* Drag mode — the gap under the dragged card opens up, bumping the timeline\\n     apart to make room for the incoming event. */\\n  .slot.drop{min-height:58px;background:var(--soft);border-style:solid;border-color:var(--fg)}\\n  .slot.drop::before{background:var(--fg);border-color:var(--fg)}\\n  .slot.drop::after{content:\\\"Drop event here\\\";font-weight:700}\\n  body.mode-drag .deal{cursor:grab}\\n  body.mode-drag.dragging .deal{cursor:grabbing;opacity:.55}\\n  body.mode-drag .deal .thumb img,body.mode-drag .deal .thumb{pointer-events:none}\\n  /* While a placement is being revealed the gaps don't respond — don't let them\\n     keep advertising themselves as clickable. */\\n  .timeline.locked .slot{cursor:default;border-color:transparent;background:transparent}\\n  .timeline.locked .slot::before{opacity:.35}\\n  .timeline.locked .slot::after{opacity:0}\\n  .timeline.locked .slot.sel{border-color:var(--fg)}\\n\\n  .card{position:relative;display:flex;gap:.7rem;align-items:center;background:var(--bg);\\n        border:1px solid var(--line2);padding:.6rem .75rem;margin:.1rem 0}\\n  .card .dot{position:absolute;left:-21px;top:50%;transform:translateY(-50%);width:11px;height:11px;\\n             border-radius:50%;background:var(--fg);border:2px solid var(--bg)}\\n  .card.correct .dot{background:var(--good)}\\n  .card.wrong .dot{background:var(--bad)}\\n  .thumb{width:44px;height:44px;flex:none;object-fit:cover;background:var(--soft);\\n         display:grid;place-items:center;font-weight:700;color:var(--fg);font-size:1.1rem;overflow:hidden}\\n  .thumb img{width:100%;height:100%;object-fit:cover}\\n  .card .body{min-width:0;flex:1}\\n  .card .ct{margin:0;font-size:.92rem;font-weight:700;line-height:1.25}\\n  .card .cd{font-size:.8rem;margin-top:.15rem}\\n  .card.correct .cd{color:var(--good)}\\n  .card.wrong .cd{color:var(--bad)}\\n  .card .badge{position:absolute;right:.7rem;top:-.62rem;font-size:.72rem;font-weight:700;\\n               padding:.08rem .45rem;background:var(--bg);border:1px solid var(--line);opacity:0}\\n  .card.anchor .badge{opacity:1}\\n  .card.just .badge{opacity:1}\\n  .card.correct.just .badge{color:var(--good);border-color:var(--good)}\\n  .card.wrong.just .badge{color:var(--bad);border-color:var(--bad)}\\n  .card.popping{animation:pop .5s cubic-bezier(.2,1.3,.4,1)}\\n  @keyframes pop{0%{transform:scale(.7);opacity:0}60%{transform:scale(1.04)}100%{transform:scale(1);opacity:1}}\\n\\n  /* The deal tray — the current card to place. */\\n  .tray{position:sticky;bottom:0;z-index:20;margin-top:1rem;background:var(--bg)}\\n  .tray-inner{background:var(--bg);border:1px solid var(--line);padding:1rem}\\n  .deal{display:flex;gap:.9rem;align-items:flex-start}\\n  .deal .thumb{width:60px;height:60px;font-size:1.4rem}\\n  .deal .body{flex:1;min-width:0}\\n  .deal .hint{font-size:.74rem}\\n  .deal h2{font-family:var(--title);border:0;padding:0;margin:.1rem 0 .25rem;font-size:1.1rem;line-height:1.25}\\n  .deal p{margin:0;font-size:.9rem}\\n  .commit{display:flex;gap:.6rem;align-items:center;margin-top:.85rem}\\n  .commit .pick{flex:1;font-size:.86rem}\\n  .btn{background:var(--soft);color:var(--fg);border:1px solid var(--line);\\n       padding:.5rem 1.2rem;font-weight:700;font-size:.92rem;cursor:pointer;\\n       font-family:inherit;text-decoration:none;display:inline-block}\\n  .btn:hover:not(:disabled){background:var(--soft2);border-color:var(--fg);text-decoration:none}\\n  .btn.primary{border-color:var(--fg)}\\n  .btn:disabled{color:var(--muted);cursor:not-allowed}\\n  .float{position:fixed;left:50%;transform:translateX(-50%);z-index:40;font-weight:800;\\n         pointer-events:none;animation:rise 1s ease forwards}\\n  @keyframes rise{0%{opacity:0;transform:translate(-50%,10px) scale(.8)}\\n                  20%{opacity:1}100%{opacity:0;transform:translate(-50%,-46px) scale(1.1)}}\\n\\n  /* Results. */\\n  .results{text-align:center;padding:1.2rem 0 .8rem}\\n  .results .restitle{font-family:var(--title);font-size:1rem}\\n  .results .grade{font-family:var(--title);font-size:2.2rem;margin:.15rem 0}\\n  .results .acc b{font-weight:700}\\n  .reslist{margin:1.3rem 0;text-align:left;border:1px solid var(--line)}\\n  .resrow{display:flex;gap:.7rem;align-items:center;padding:.55rem .8rem;border-bottom:1px solid var(--line2)}\\n  .resrow:last-child{border-bottom:0}\\n  .resrow .mk{font-size:1rem}\\n  .resrow .rt{flex:1;min-width:0}\\n  .resrow .rt .n{font-size:.92rem;font-weight:700}\\n  .resrow .rt .d{font-size:.78rem}\\n  .resrow a{font-size:.84rem;white-space:nowrap}\\n  .actions{display:flex;gap:.7rem;justify-content:center;flex-wrap:wrap;margin-top:1.3rem}\\n</style>\\n</head>\\n<body>\\n${pageHeader({ back: true })}\\n${bodyHeader({\\n  left: `<span id=\\\"sub\\\">${puzzle.events.length} events to place</span>`,\\n  right: `<span id=\\\"stats\\\">Score&nbsp;<b id=\\\"score\\\">0</b> · Streak&nbsp;<b id=\\\"streak\\\">0</b></span>${authChip()}`,\\n})}\\n\\n<main class=\\\"wrap board-wrap\\\">\\n  <h1>${escapeHtml(theme)}</h1>\\n  <p class=\\\"meta\\\">${meta}</p>\\n  <div class=\\\"modes\\\">\\n    <span class=\\\"modes-label\\\">Placement mode</span>\\n    <div class=\\\"modeset\\\" id=\\\"modes\\\" role=\\\"tablist\\\" aria-label=\\\"Placement mode\\\">\\n      <button class=\\\"modebtn\\\" type=\\\"button\\\" data-mode=\\\"click\\\" role=\\\"tab\\\" aria-selected=\\\"true\\\">Click to place</button>\\n      <button class=\\\"modebtn\\\" type=\\\"button\\\" data-mode=\\\"keyboard\\\" role=\\\"tab\\\" aria-selected=\\\"false\\\">Keyboard</button>\\n      <button class=\\\"modebtn\\\" type=\\\"button\\\" data-mode=\\\"drag\\\" role=\\\"tab\\\" aria-selected=\\\"false\\\">Drag &amp; drop</button>\\n    </div>\\n  </div>\\n  <div class=\\\"progress\\\"><i id=\\\"bar\\\"></i></div>\\n  <div id=\\\"board\\\" aria-live=\\\"polite\\\"></div>\\n</main>\\n\\n<script id=\\\"puzzle\\\" type=\\\"application/json\\\">${inlineJson(puzzle)}</script>\\n<script>\\n${AUTH_CHIP_SCRIPT}\\n</script>\\n<script>\\n${ENGINE}\\n</script>\\n</body>\\n</html>`;\\n}\\n\\n// The client engine is a single template string so it ships verbatim with no\\n// bundler. It is plain ES2020 — no framework, no dependencies.\\nconst ENGINE = String.raw`\\n(function(){\\n  \\\"use strict\\\";\\n  var puzzle = JSON.parse(document.getElementById('puzzle').textContent);\\n  var board = document.getElementById('board');\\n  var elScore = document.getElementById('score');\\n  var elStreak = document.getElementById('streak');\\n  var elStreakBox = elStreak.parentElement;\\n  var elBar = document.getElementById('bar');\\n  var elSub = document.getElementById('sub');\\n  var modesEl = document.getElementById('modes');\\n\\n  var POINTS = 100, STREAK_BONUS = 25;\\n\\n  // ---- placement modes --------------------------------------------------\\n  // Three interchangeable input prototypes drive the same engine: 'click'\\n  // (tap a gap + Commit), 'keyboard' (arrow between gaps + Enter), and 'drag'\\n  // (drag the dealt card onto a gap). The choice persists across sessions.\\n  var MODES = ['click','keyboard','drag'];\\n  function loadMode(){ try{ var m=localStorage.getItem('timealign-mode'); return MODES.indexOf(m)>=0?m:'click'; }catch(e){ return 'click'; } }\\n  function saveMode(m){ try{ localStorage.setItem('timealign-mode', m); }catch(e){} }\\n  function applyModeUI(){\\n    if (modesEl) modesEl.querySelectorAll('.modebtn').forEach(function(b){\\n      b.setAttribute('aria-selected', b.getAttribute('data-mode')===state.mode ? 'true':'false');\\n    });\\n    document.body.classList.remove('mode-click','mode-keyboard','mode-drag');\\n    document.body.classList.add('mode-'+state.mode);\\n  }\\n  function setMode(m){\\n    if (MODES.indexOf(m)<0 || m===state.mode) return;\\n    state.mode = m; saveMode(m);\\n    // Keyboard mode wants a starting cursor so the arrows have something to move.\\n    if (m==='keyboard' && state.sel===null && !state.locked && state.current) state.sel = Math.floor(state.placed.length/2);\\n    applyModeUI(); render();\\n    if (m==='keyboard') scrollSelIntoView();\\n  }\\n  function scrollSelIntoView(){ var s=board.querySelector('.slot.sel'); if(s&&s.scrollIntoView) s.scrollIntoView({block:'nearest'}); }\\n\\n  // ---- helpers ----------------------------------------------------------\\n  function shuffle(a){ a = a.slice(); for(var i=a.length-1;i>0;i--){var j=Math.floor(Math.random()*(i+1));var t=a[i];a[i]=a[j];a[j]=t;} return a; }\\n  function byDate(a,b){ return a.date < b.date ? -1 : a.date > b.date ? 1 : 0; }\\n  function esc(s){ return String(s).replace(/[&<>\\\"']/g,function(c){return({'&':'&amp;','<':'&lt;','>':'&gt;','\\\"':'&quot;',\\\"'\\\":'&#39;'})[c];}); }\\n  function titleFromUrl(u){ try{ var p=u.split('/wiki/')[1]; return decodeURIComponent(p); }catch(e){ return null; } }\\n  function initials(t){ var m=t.replace(/^[^A-Za-z0-9]+/,'').match(/[A-Za-z0-9]/); return m?m[0].toUpperCase():'?'; }\\n\\n  // ---- image prefetch (progressive enhancement) -------------------------\\n  // Use the event's imageUrl if authored, else lazily resolve a thumbnail from\\n  // the Wikipedia REST summary endpoint. Failures fall back to a typographic\\n  // tile, so the game never depends on the network.\\n  var imageCache = {};\\n  function loadImage(ev){\\n    if (imageCache[ev.id] !== undefined) return Promise.resolve(imageCache[ev.id]);\\n    if (ev.imageUrl){ imageCache[ev.id]=ev.imageUrl; return Promise.resolve(ev.imageUrl); }\\n    var title = titleFromUrl(ev.wikipediaUrl);\\n    if (!title){ imageCache[ev.id]=null; return Promise.resolve(null); }\\n    var api = 'https://en.wikipedia.org/api/rest_v1/page/summary/' + encodeURIComponent(title);\\n    return fetch(api).then(function(r){ return r.ok ? r.json() : null; }).then(function(d){\\n      var src = d && d.thumbnail && d.thumbnail.source ? d.thumbnail.source : null;\\n      imageCache[ev.id] = src; return src;\\n    }).catch(function(){ imageCache[ev.id]=null; return null; });\\n  }\\n  function paintThumb(el, ev){\\n    el.textContent = initials(ev.title);\\n    loadImage(ev).then(function(src){\\n      if(!src) return;\\n      var img = new Image();\\n      img.alt = '';\\n      img.onload = function(){ el.textContent=''; el.appendChild(img); };\\n      img.src = src;\\n    });\\n  }\\n\\n  // ---- game state -------------------------------------------------------\\n  var state;\\n  function newGame(){\\n    var all = shuffle(puzzle.events);\\n    var chrono = all.slice().sort(byDate);\\n    var anchor = chrono[Math.floor(chrono.length/2)]; // chronologically middle\\n    var queue = shuffle(all.filter(function(e){ return e.id !== anchor.id; }));\\n    state = {\\n      placed: [Object.assign({}, anchor, {status:'anchor'})],\\n      queue: queue,\\n      total: queue.length,\\n      sel: null,\\n      score: 0,\\n      streak: 0,\\n      correct: 0,\\n      done: 0,\\n      locked: false,\\n      justId: null,\\n      wrongReveal: null,\\n      wrongPhase: false,\\n      animateJust: false,\\n      mode: loadMode()\\n    };\\n    // warm the cache so thumbnails are ready when a card surfaces\\n    puzzle.events.forEach(loadImage);\\n    applyModeUI();\\n    render();\\n  }\\n\\n  function correctIndex(ev){\\n    var i = 0;\\n    while (i < state.placed.length && state.placed[i].date < ev.date) i++;\\n    return i;\\n  }\\n\\n  // ---- rendering --------------------------------------------------------\\n  function cardHtml(ev, cls){\\n    var dateLine = ev.status==='hidden' ? '' :\\n      '<div class=\\\"cd\\\">'+esc(ev.displayDate)+'</div>';\\n    var badge = '';\\n    if (ev.status==='anchor') badge='<span class=\\\"badge\\\">Anchor</span>';\\n    else if (ev.id===state.justId){ if(ev.status==='correct') badge='<span class=\\\"badge\\\">correct</span>'; else if(state.wrongPhase) badge='<span class=\\\"badge\\\" style=\\\"color:var(--bad);border-color:var(--bad)\\\">wrong</span>'; else badge='<span class=\\\"badge\\\">actually here</span>'; }\\n    return '<div class=\\\"card '+cls+'\\\" data-ev=\\\"'+esc(ev.id)+'\\\">'+\\n      '<span class=\\\"dot\\\"></span>'+\\n      '<span class=\\\"thumb\\\" data-thumb=\\\"'+esc(ev.id)+'\\\"></span>'+\\n      '<div class=\\\"body\\\"><p class=\\\"ct\\\">'+esc(ev.title)+'</p>'+dateLine+'</div>'+\\n      badge+'</div>';\\n  }\\n\\n  // Mode-specific instruction shown above the Commit button.\\n  function pickHint(){\\n    if (state.sel !== null) return 'Gap selected — press <b>Enter</b> or click Commit';\\n    if (state.mode==='drag') return 'Drag this card onto a gap ↑, then press <b>Enter</b> or Commit';\\n    if (state.mode==='keyboard') return 'Press <b>↑ / ↓</b> to choose a gap, then <b>Enter</b> or Commit';\\n    return 'Tap a marked gap on the timeline ↑, then press <b>Enter</b> or Commit';\\n  }\\n\\n  function render(){\\n    if (state.queue.length===0 && !state.current){ return renderResults(); }\\n    if (!state.current) state.current = state.queue.shift();\\n    state.placed.sort(byDate);\\n\\n    // During the wrong-reveal phase, temporarily show the card at the player's\\n    // chosen (wrong) slot so the correction is visually obvious.\\n    var displayPlaced = state.placed;\\n    if (state.wrongReveal) {\\n      var wr = state.wrongReveal;\\n      displayPlaced = state.placed.filter(function(e){ return e.id !== wr.ev.id; });\\n      displayPlaced.splice(wr.slot, 0, wr.ev);\\n    }\\n\\n    elSub.textContent = (state.done+1)+' of '+(state.total)+' to place';\\n    elBar.style.width = Math.round((state.done/state.total)*100)+'%';\\n\\n    var html = '<div class=\\\"timeline'+(state.locked?' locked':'')+'\\\" id=\\\"tl\\\">';\\n    html += '<div class=\\\"axis-cap top\\\"><span class=\\\"cap-arrow\\\" aria-hidden=\\\"true\\\">↑</span>Earlier in time</div>';\\n    for (var i=0;i<=displayPlaced.length;i++){\\n      html += '<div class=\\\"slot'+(state.sel===i?' sel':'')+'\\\" data-slot=\\\"'+i+'\\\" role=\\\"button\\\" tabindex=\\\"0\\\" aria-label=\\\"Place event in position '+(i+1)+' of '+(displayPlaced.length+1)+'\\\"></div>';\\n      if (i < displayPlaced.length){\\n        var ev = displayPlaced[i];\\n        var cls = (ev.status||'') + (ev.id===state.justId?' just':'') + (ev.id===state.justId&&state.animateJust?' popping':'');\\n        html += cardHtml(ev, cls.trim());\\n      }\\n    }\\n    html += '<div class=\\\"axis-cap bottom\\\"><span class=\\\"cap-arrow\\\" aria-hidden=\\\"true\\\">↓</span>Later in time</div>';\\n    html += '</div>';\\n\\n    var cur = state.current;\\n    html += '<div class=\\\"tray\\\"><div class=\\\"tray-inner\\\">'+\\n      '<div class=\\\"deal\\\" id=\\\"deal\\\">'+\\n        '<span class=\\\"thumb\\\" data-thumb=\\\"'+esc(cur.id)+'\\\"></span>'+\\n        '<div class=\\\"body\\\"><div class=\\\"hint\\\">Where does this go?</div>'+\\n          '<h2>'+esc(cur.title)+'</h2><p>'+esc(cur.summary)+'</p></div>'+\\n      '</div>'+\\n      '<div class=\\\"commit\\\">'+\\n        '<div class=\\\"pick\\\" id=\\\"pick\\\">'+pickHint()+'</div>'+\\n        '<button class=\\\"btn primary\\\" id=\\\"commit\\\"'+(state.sel===null?' disabled':'')+'>Commit</button>'+\\n      '</div>'+\\n    '</div></div>';\\n\\n    board.innerHTML = html;\\n    // thumbnails\\n    board.querySelectorAll('[data-thumb]').forEach(function(el){\\n      var id = el.getAttribute('data-thumb');\\n      var ev = (id===cur.id) ? cur : state.placed.filter(function(e){return e.id===id;})[0];\\n      if (ev) paintThumb(el, ev);\\n    });\\n    wire();\\n  }\\n\\n  function wire(){\\n    board.querySelectorAll('.slot').forEach(function(s){\\n      var idx = parseInt(s.getAttribute('data-slot'),10);\\n      var choose = function(){ if(state.locked) return; state.sel = idx; render(); };\\n      s.addEventListener('click', choose);\\n      s.addEventListener('keydown', function(e){ if(e.key==='Enter'||e.key===' '){ e.preventDefault(); choose(); } });\\n      if (state.mode==='drag'){\\n        s.addEventListener('dragenter', function(e){ if(state.locked) return; e.preventDefault(); s.classList.add('drop'); });\\n        s.addEventListener('dragover', function(e){ if(state.locked) return; e.preventDefault(); if(e.dataTransfer) e.dataTransfer.dropEffect='move'; s.classList.add('drop'); });\\n        s.addEventListener('dragleave', function(){ s.classList.remove('drop'); });\\n        s.addEventListener('drop', function(e){ if(state.locked) return; e.preventDefault(); s.classList.remove('drop'); state.sel = idx; render(); });\\n      }\\n    });\\n    var c = document.getElementById('commit');\\n    if (c) c.addEventListener('click', commit);\\n    if (state.mode==='drag'){\\n      var deal = document.getElementById('deal');\\n      if (deal){\\n        deal.setAttribute('draggable','true');\\n        deal.addEventListener('dragstart', function(e){\\n          if(state.locked){ e.preventDefault(); return; }\\n          document.body.classList.add('dragging');\\n          if(e.dataTransfer){ e.dataTransfer.effectAllowed='move'; try{ e.dataTransfer.setData('text/plain', String(state.current && state.current.id)); }catch(_){} }\\n        });\\n        deal.addEventListener('dragend', function(){\\n          document.body.classList.remove('dragging');\\n          board.querySelectorAll('.slot.drop').forEach(function(x){ x.classList.remove('drop'); });\\n        });\\n      }\\n    }\\n  }\\n\\n  function commit(){\\n    if (state.locked || state.sel===null) return;\\n    state.locked = true;\\n    var cur = state.current;\\n    var want = correctIndex(cur);\\n    var ok = state.sel === want;\\n    var wrongSlot = state.sel;\\n\\n    var gained = 0;\\n    if (ok){ gained = POINTS + STREAK_BONUS*state.streak; state.streak++; state.correct++; }\\n    else { state.streak = 0; }\\n    state.score += gained;\\n\\n    // Always insert at the correct chronological position; a wrong guess snaps\\n    // to where it belongs after a brief reveal at the player's chosen slot.\\n    cur.status = ok ? 'correct' : 'wrong';\\n    state.placed.push(cur);\\n    state.placed.sort(byDate);\\n    state.justId = cur.id;\\n    state.done++;\\n    state.sel = null;\\n    state.current = null;\\n\\n    updateStats(gained, ok);\\n\\n    if (!ok) {\\n      // Phase 1: show the card at the player's (wrong) slot with a red badge.\\n      state.wrongReveal = { slot: wrongSlot, ev: cur };\\n      state.wrongPhase = true;\\n      state.animateJust = false;\\n      render();\\n      setTimeout(function(){\\n        // Phase 2: snap the card to its correct position with the pop animation.\\n        state.wrongReveal = null;\\n        state.wrongPhase = false;\\n        state.animateJust = true;\\n        render();\\n        state.animateJust = false;\\n        setTimeout(function(){ state.locked = false; render(); }, 400);\\n      }, 700);\\n    } else {\\n      state.animateJust = true;\\n      render();\\n      state.animateJust = false;\\n      setTimeout(function(){ state.locked = false; render(); }, 500);\\n    }\\n  }\\n\\n  function updateStats(gained, ok){\\n    elScore.textContent = state.score;\\n    elStreak.textContent = state.streak;\\n    if (state.streak>0) elStreakBox.classList.remove('cold'); else elStreakBox.classList.add('cold');\\n    if (gained>0) floatText('+'+gained, 'var(--good)');\\n    else floatText(ok?'+0':'missed', 'var(--bad)');\\n  }\\n\\n  function floatText(txt, color){\\n    var f = document.createElement('div');\\n    f.className='float'; f.textContent=txt; f.style.color=color; f.style.top='64px'; f.style.fontSize='1.3rem';\\n    document.body.appendChild(f);\\n    setTimeout(function(){ f.remove(); }, 1000);\\n  }\\n\\n  // ---- results ----------------------------------------------------------\\n  function renderResults(){\\n    elBar.style.width='100%';\\n    elSub.textContent='Complete';\\n    var chrono = state.placed.slice().sort(byDate);\\n    var acc = state.correct + ' / ' + state.total;\\n    var pct = Math.round((state.correct/state.total)*100);\\n    var grade = pct===100?'Perfect!':pct>=80?'Sharp eye':pct>=50?'Not bad':'Keep going';\\n\\n    var rows = chrono.map(function(ev){\\n      var mk = ev.status==='wrong' ? '✕' : '✓';\\n      var col = ev.status==='wrong' ? 'var(--bad)' : (ev.status==='anchor'?'#000':'var(--good)');\\n      return '<div class=\\\"resrow\\\">'+\\n        '<span class=\\\"mk\\\" style=\\\"color:'+col+'\\\">'+mk+'</span>'+\\n        '<div class=\\\"rt\\\"><div class=\\\"n\\\">'+esc(ev.title)+'</div><div class=\\\"d\\\">'+esc(ev.displayDate)+'</div></div>'+\\n        '<a href=\\\"'+esc(ev.wikipediaUrl)+'\\\" target=\\\"_blank\\\" rel=\\\"noopener\\\">Dive deeper ↗</a>'+\\n      '</div>';\\n    }).join('');\\n\\n    board.innerHTML =\\n      '<div class=\\\"results\\\">'+\\n        '<div class=\\\"restitle\\\">'+esc(puzzle.theme||'Results')+'</div>'+\\n        '<div class=\\\"grade\\\">'+esc(grade)+'</div>'+\\n        '<div class=\\\"acc\\\">You placed <b>'+acc+'</b> correctly · <b>'+state.score+'</b> points</div>'+\\n      '</div>'+\\n      '<div class=\\\"reslist\\\">'+rows+'</div>'+\\n      '<div class=\\\"actions\\\">'+\\n        '<button class=\\\"btn primary\\\" id=\\\"again\\\">Play again</button>'+\\n        '<a class=\\\"btn\\\" href=\\\"/\\\">More puzzles</a>'+\\n      '</div>';\\n    var a = document.getElementById('again');\\n    if (a) a.addEventListener('click', function(){ newGame(); window.scrollTo(0,0); });\\n  }\\n\\n  // Mode switcher — wired once; it persists across re-renders and replays.\\n  if (modesEl) modesEl.querySelectorAll('.modebtn').forEach(function(b){\\n    b.addEventListener('click', function(){ setMode(b.getAttribute('data-mode')); });\\n  });\\n\\n  // Global keyboard handler — Enter commits a selected gap in any mode;\\n  // ↑/↓ navigate between gaps in keyboard mode.\\n  document.addEventListener('keydown', function(e){\\n    if (state.locked || !state.current) return;\\n    if (e.key==='Enter' && state.sel!==null){ e.preventDefault(); commit(); return; }\\n    if (state.mode!=='keyboard') return;\\n    var max = state.placed.length; // gaps are indexed 0..placed.length\\n    if (e.key==='ArrowDown' || e.key==='ArrowUp'){\\n      e.preventDefault();\\n      if (state.sel===null) state.sel = e.key==='ArrowDown' ? 0 : max;\\n      else { state.sel += e.key==='ArrowDown' ? 1 : -1; state.sel = Math.max(0, Math.min(max, state.sel)); }\\n      render(); scrollSelIntoView();\\n    }\\n  });\\n\\n  newGame();\\n})();\\n`;\\n\"}"}]}]},"parent_tool_use_id":null,"session_id":"c27551c5-5b00-415d-b0c5-1962998d9b34","uuid":"97d428ac-f9d6-4e66-a20f-e3e14935178e","timestamp":"2026-06-18T17:40:17.943Z","tool_use_result":[{"type":"text","text":"{\"path\":\"src/game.ts\",\"ref\":\"agent/issue-6\",\"size\":25747,\"content\":\"// The game board served at /play/:id. The full puzzle (dates included) is\\n// inlined into the page; the client engine hides each date until the player\\n// commits, then reveals it with the snap/flash animations that are the\\n// emotional core of the game. Server-rendering the data avoids a loading flash\\n// and a round-trip — the /api/puzzles routes still expose the same contract.\\nimport type { Puzzle } from \\\"./puzzles.js\\\";\\nimport {\\n  AUTH_CHIP_SCRIPT,\\n  authChip,\\n  bodyHeader,\\n  escapeHtml,\\n  inlineJson,\\n  PAGE_CSS,\\n  pageHeader,\\n} from \\\"./ui.js\\\";\\n\\nconst DIFFICULTY_LABEL: Record<string, string> = {\\n  easy: \\\"Easy\\\",\\n  medium: \\\"Medium\\\",\\n  hard: \\\"Hard\\\",\\n};\\n\\nexport function gameBoard({\\n  app,\\n  puzzle,\\n}: {\\n  app: string;\\n  puzzle: Puzzle;\\n}): string {\\n  const theme = puzzle.theme ?? \\\"Mixed events\\\";\\n  const difficulty = DIFFICULTY_LABEL[puzzle.difficulty] ?? puzzle.difficulty;\\n  const years = puzzle.events.map((e) => Number(e.date.slice(0, 4)));\\n  const span =\\n    years.length && Math.min(...years) !== Math.max(...years)\\n      ? `${Math.min(...years)}–${Math.max(...years)}`\\n      : String(years[0] ?? \\\"—\\\");\\n  const tags = [...new Set(puzzle.events.flatMap((e) => e.tags))];\\n  const metaBits = [\\n    difficulty,\\n    span,\\n    `${puzzle.events.length} events`,\\n    ...(tags.length ? [tags.join(\\\", \\\")] : []),\\n  ];\\n  const meta = metaBits.map((b) => escapeHtml(b)).join(\\\" · \\\");\\n  return `<!doctype html>\\n<html lang=\\\"en\\\">\\n<head>\\n<meta charset=\\\"utf-8\\\">\\n<meta name=\\\"viewport\\\" content=\\\"width=device-width,initial-scale=1,maximum-scale=1\\\">\\n<title>${escapeHtml(theme)} — ${escapeHtml(app)}</title>\\n<style>\\n${PAGE_CSS}\\n  body{padding-bottom:2rem}\\n  .board-wrap{padding-top:.2rem}\\n  .meta{margin:.1rem 0 .6rem;font-size:.92rem}\\n\\n  /* Placement-mode switcher — a stark, monochrome segmented control. Lets\\n     testers swap between the three input prototypes; the choice persists. */\\n  .modes{display:flex;align-items:center;gap:.55rem;flex-wrap:wrap;margin:.2rem 0 .8rem}\\n  .modes-label{font-size:.84rem}\\n  .modeset{display:inline-flex;border:1px solid var(--line)}\\n  .modebtn{font-family:inherit;font-size:.84rem;background:var(--bg);color:var(--fg);\\n           border:0;border-left:1px solid var(--line);padding:.3rem .75rem;cursor:pointer;line-height:1.2}\\n  .modeset .modebtn:first-child{border-left:0}\\n  .modebtn:hover{background:var(--soft)}\\n  .modebtn[aria-selected=\\\"true\\\"]{background:#000;color:#fff;font-weight:700}\\n  .modebtn:focus-visible{outline:2px solid var(--fg);outline-offset:2px}\\n\\n  /* Progress — a thin neutral bar, black fill, no accent colour. */\\n  .progress{height:4px;background:var(--soft2);margin:.1rem 0 1.1rem}\\n  .progress > i{display:block;height:100%;width:0;background:#000;transition:width .4s ease}\\n\\n  /* The timeline lives in its own rectangular container, so its width stays\\n     constant however many cards it grows to hold. */\\n  .timeline{position:relative;border:1px solid var(--line);background:var(--bg);\\n            padding:.8rem 1rem .8rem 30px;margin:.2rem 0 1.1rem}\\n  .timeline::before{content:\\\"\\\";position:absolute;left:13px;top:30px;bottom:30px;width:2px;\\n                    background:var(--line)}\\n\\n  /* Direction-of-time caps so it's obvious which end is which. */\\n  .axis-cap{position:relative;height:22px;display:flex;align-items:center;\\n            font-size:.74rem;color:var(--fg)}\\n  .axis-cap .cap-arrow{position:absolute;left:-21px;width:11px;text-align:center;\\n                       font-size:1.05rem;line-height:1}\\n\\n  /* Insertion gaps — always visibly marked as drop targets, not hover-only. */\\n  .slot{position:relative;min-height:28px;margin:5px 0;cursor:pointer;\\n        border:1px dashed var(--line);background:transparent;display:flex;align-items:center;\\n        transition:min-height .18s ease,background .18s ease,border-color .18s ease}\\n  .slot::before{content:\\\"\\\";position:absolute;left:-21px;top:50%;transform:translateY(-50%);\\n                width:11px;height:11px;border-radius:50%;background:var(--bg);\\n                border:2px solid var(--line);transition:background .15s,border-color .15s}\\n  .slot::after{content:\\\"＋ Place here\\\";position:absolute;left:11px;top:50%;transform:translateY(-50%);\\n               font-size:.74rem;color:var(--fg);transition:color .15s}\\n  .slot:hover{background:var(--soft);border-color:var(--fg)}\\n  .slot:hover::before{background:var(--fg);border-color:var(--fg)}\\n  .slot:focus-visible{outline:2px solid var(--fg);outline-offset:2px}\\n  .slot.sel{min-height:46px;background:var(--soft);border-style:solid;border-color:var(--fg)}\\n  .slot.sel::before{background:var(--fg);border-color:var(--fg)}\\n  .slot.sel::after{content:\\\"Place here ✓\\\";font-weight:700}\\n  /* Drag mode — the gap under the dragged card opens up, bumping the timeline\\n     apart to make room for the incoming event. */\\n  .slot.drop{min-height:58px;background:var(--soft);border-style:solid;border-color:var(--fg)}\\n  .slot.drop::before{background:var(--fg);border-color:var(--fg)}\\n  .slot.drop::after{content:\\\"Drop event here\\\";font-weight:700}\\n  body.mode-drag .deal{cursor:grab}\\n  body.mode-drag.dragging .deal{cursor:grabbing;opacity:.55}\\n  body.mode-drag .deal .thumb img,body.mode-drag .deal .thumb{pointer-events:none}\\n  /* While a placement is being revealed the gaps don't respond — don't let them\\n     keep advertising themselves as clickable. */\\n  .timeline.locked .slot{cursor:default;border-color:transparent;background:transparent}\\n  .timeline.locked .slot::before{opacity:.35}\\n  .timeline.locked .slot::after{opacity:0}\\n  .timeline.locked .slot.sel{border-color:var(--fg)}\\n\\n  .card{position:relative;display:flex;gap:.7rem;align-items:center;background:var(--bg);\\n        border:1px solid var(--line2);padding:.6rem .75rem;margin:.1rem 0}\\n  .card .dot{position:absolute;left:-21px;top:50%;transform:translateY(-50%);width:11px;height:11px;\\n             border-radius:50%;background:var(--fg);border:2px solid var(--bg)}\\n  .card.correct .dot{background:var(--good)}\\n  .card.wrong .dot{background:var(--bad)}\\n  .thumb{width:44px;height:44px;flex:none;object-fit:cover;background:var(--soft);\\n         display:grid;place-items:center;font-weight:700;color:var(--fg);font-size:1.1rem;overflow:hidden}\\n  .thumb img{width:100%;height:100%;object-fit:cover}\\n  .card .body{min-width:0;flex:1}\\n  .card .ct{margin:0;font-size:.92rem;font-weight:700;line-height:1.25}\\n  .card .cd{font-size:.8rem;margin-top:.15rem}\\n  .card.correct .cd{color:var(--good)}\\n  .card.wrong .cd{color:var(--bad)}\\n  .card .badge{position:absolute;right:.7rem;top:-.62rem;font-size:.72rem;font-weight:700;\\n               padding:.08rem .45rem;background:var(--bg);border:1px solid var(--line);opacity:0}\\n  .card.anchor .badge{opacity:1}\\n  .card.just .badge{opacity:1}\\n  .card.correct.just .badge{color:var(--good);border-color:var(--good)}\\n  .card.wrong.just .badge{color:var(--bad);border-color:var(--bad)}\\n  .card.popping{animation:pop .5s cubic-bezier(.2,1.3,.4,1)}\\n  @keyframes pop{0%{transform:scale(.7);opacity:0}60%{transform:scale(1.04)}100%{transform:scale(1);opacity:1}}\\n\\n  /* The deal tray — the current card to place. */\\n  .tray{position:sticky;bottom:0;z-index:20;margin-top:1rem;background:var(--bg)}\\n  .tray-inner{background:var(--bg);border:1px solid var(--line);padding:1rem}\\n  .deal{display:flex;gap:.9rem;align-items:flex-start}\\n  .deal .thumb{width:60px;height:60px;font-size:1.4rem}\\n  .deal .body{flex:1;min-width:0}\\n  .deal .hint{font-size:.74rem}\\n  .deal h2{font-family:var(--title);border:0;padding:0;margin:.1rem 0 .25rem;font-size:1.1rem;line-height:1.25}\\n  .deal p{margin:0;font-size:.9rem}\\n  .commit{display:flex;gap:.6rem;align-items:center;margin-top:.85rem}\\n  .commit .pick{flex:1;font-size:.86rem}\\n  .btn{background:var(--soft);color:var(--fg);border:1px solid var(--line);\\n       padding:.5rem 1.2rem;font-weight:700;font-size:.92rem;cursor:pointer;\\n       font-family:inherit;text-decoration:none;display:inline-block}\\n  .btn:hover:not(:disabled){background:var(--soft2);border-color:var(--fg);text-decoration:none}\\n  .btn.primary{border-color:var(--fg)}\\n  .btn:disabled{color:var(--muted);cursor:not-allowed}\\n  .float{position:fixed;left:50%;transform:translateX(-50%);z-index:40;font-weight:800;\\n         pointer-events:none;animation:rise 1s ease forwards}\\n  @keyframes rise{0%{opacity:0;transform:translate(-50%,10px) scale(.8)}\\n                  20%{opacity:1}100%{opacity:0;transform:translate(-50%,-46px) scale(1.1)}}\\n\\n  /* Results. */\\n  .results{text-align:center;padding:1.2rem 0 .8rem}\\n  .results .restitle{font-family:var(--title);font-size:1rem}\\n  .results .grade{font-family:var(--title);font-size:2.2rem;margin:.15rem 0}\\n  .results .acc b{font-weight:700}\\n  .reslist{margin:1.3rem 0;text-align:left;border:1px solid var(--line)}\\n  .resrow{display:flex;gap:.7rem;align-items:center;padding:.55rem .8rem;border-bottom:1px solid var(--line2)}\\n  .resrow:last-child{border-bottom:0}\\n  .resrow .mk{font-size:1rem}\\n  .resrow .rt{flex:1;min-width:0}\\n  .resrow .rt .n{font-size:.92rem;font-weight:700}\\n  .resrow .rt .d{font-size:.78rem}\\n  .resrow a{font-size:.84rem;white-space:nowrap}\\n  .actions{display:flex;gap:.7rem;justify-content:center;flex-wrap:wrap;margin-top:1.3rem}\\n</style>\\n</head>\\n<body>\\n${pageHeader({ back: true })}\\n${bodyHeader({\\n  left: `<span id=\\\"sub\\\">${puzzle.events.length} events to place</span>`,\\n  right: `<span id=\\\"stats\\\">Score&nbsp;<b id=\\\"score\\\">0</b> · Streak&nbsp;<b id=\\\"streak\\\">0</b></span>${authChip()}`,\\n})}\\n\\n<main class=\\\"wrap board-wrap\\\">\\n  <h1>${escapeHtml(theme)}</h1>\\n  <p class=\\\"meta\\\">${meta}</p>\\n  <div class=\\\"modes\\\">\\n    <span class=\\\"modes-label\\\">Placement mode</span>\\n    <div class=\\\"modeset\\\" id=\\\"modes\\\" role=\\\"tablist\\\" aria-label=\\\"Placement mode\\\">\\n      <button class=\\\"modebtn\\\" type=\\\"button\\\" data-mode=\\\"click\\\" role=\\\"tab\\\" aria-selected=\\\"true\\\">Click to place</button>\\n      <button class=\\\"modebtn\\\" type=\\\"button\\\" data-mode=\\\"keyboard\\\" role=\\\"tab\\\" aria-selected=\\\"false\\\">Keyboard</button>\\n      <button class=\\\"modebtn\\\" type=\\\"button\\\" data-mode=\\\"drag\\\" role=\\\"tab\\\" aria-selected=\\\"false\\\">Drag &amp; drop</button>\\n    </div>\\n  </div>\\n  <div class=\\\"progress\\\"><i id=\\\"bar\\\"></i></div>\\n  <div id=\\\"board\\\" aria-live=\\\"polite\\\"></div>\\n</main>\\n\\n<script id=\\\"puzzle\\\" type=\\\"application/json\\\">${inlineJson(puzzle)}</script>\\n<script>\\n${AUTH_CHIP_SCRIPT}\\n</script>\\n<script>\\n${ENGINE}\\n</script>\\n</body>\\n</html>`;\\n}\\n\\n// The client engine is a single template string so it ships verbatim with no\\n// bundler. It is plain ES2020 — no framework, no dependencies.\\nconst ENGINE = String.raw`\\n(function(){\\n  \\\"use strict\\\";\\n  var puzzle = JSON.parse(document.getElementById('puzzle').textContent);\\n  var board = document.getElementById('board');\\n  var elScore = document.getElementById('score');\\n  var elStreak = document.getElementById('streak');\\n  var elStreakBox = elStreak.parentElement;\\n  var elBar = document.getElementById('bar');\\n  var elSub = document.getElementById('sub');\\n  var modesEl = document.getElementById('modes');\\n\\n  var POINTS = 100, STREAK_BONUS = 25;\\n\\n  // ---- placement modes --------------------------------------------------\\n  // Three interchangeable input prototypes drive the same engine: 'click'\\n  // (tap a gap + Commit), 'keyboard' (arrow between gaps + Enter), and 'drag'\\n  // (drag the dealt card onto a gap). The choice persists across sessions.\\n  var MODES = ['click','keyboard','drag'];\\n  function loadMode(){ try{ var m=localStorage.getItem('timealign-mode'); return MODES.indexOf(m)>=0?m:'click'; }catch(e){ return 'click'; } }\\n  function saveMode(m){ try{ localStorage.setItem('timealign-mode', m); }catch(e){} }\\n  function applyModeUI(){\\n    if (modesEl) modesEl.querySelectorAll('.modebtn').forEach(function(b){\\n      b.setAttribute('aria-selected', b.getAttribute('data-mode')===state.mode ? 'true':'false');\\n    });\\n    document.body.classList.remove('mode-click','mode-keyboard','mode-drag');\\n    document.body.classList.add('mode-'+state.mode);\\n  }\\n  function setMode(m){\\n    if (MODES.indexOf(m)<0 || m===state.mode) return;\\n    state.mode = m; saveMode(m);\\n    // Keyboard mode wants a starting cursor so the arrows have something to move.\\n    if (m==='keyboard' && state.sel===null && !state.locked && state.current) state.sel = Math.floor(state.placed.length/2);\\n    applyModeUI(); render();\\n    if (m==='keyboard') scrollSelIntoView();\\n  }\\n  function scrollSelIntoView(){ var s=board.querySelector('.slot.sel'); if(s&&s.scrollIntoView) s.scrollIntoView({block:'nearest'}); }\\n\\n  // ---- helpers ----------------------------------------------------------\\n  function shuffle(a){ a = a.slice(); for(var i=a.length-1;i>0;i--){var j=Math.floor(Math.random()*(i+1));var t=a[i];a[i]=a[j];a[j]=t;} return a; }\\n  function byDate(a,b){ return a.date < b.date ? -1 : a.date > b.date ? 1 : 0; }\\n  function esc(s){ return String(s).replace(/[&<>\\\"']/g,function(c){return({'&':'&amp;','<':'&lt;','>':'&gt;','\\\"':'&quot;',\\\"'\\\":'&#39;'})[c];}); }\\n  function titleFromUrl(u){ try{ var p=u.split('/wiki/')[1]; return decodeURIComponent(p); }catch(e){ return null; } }\\n  function initials(t){ var m=t.replace(/^[^A-Za-z0-9]+/,'').match(/[A-Za-z0-9]/); return m?m[0].toUpperCase():'?'; }\\n\\n  // ---- image prefetch (progressive enhancement) -------------------------\\n  // Use the event's imageUrl if authored, else lazily resolve a thumbnail from\\n  // the Wikipedia REST summary endpoint. Failures fall back to a typographic\\n  // tile, so the game never depends on the network.\\n  var imageCache = {};\\n  function loadImage(ev){\\n    if (imageCache[ev.id] !== undefined) return Promise.resolve(imageCache[ev.id]);\\n    if (ev.imageUrl){ imageCache[ev.id]=ev.imageUrl; return Promise.resolve(ev.imageUrl); }\\n    var title = titleFromUrl(ev.wikipediaUrl);\\n    if (!title){ imageCache[ev.id]=null; return Promise.resolve(null); }\\n    var api = 'https://en.wikipedia.org/api/rest_v1/page/summary/' + encodeURIComponent(title);\\n    return fetch(api).then(function(r){ return r.ok ? r.json() : null; }).then(function(d){\\n      var src = d && d.thumbnail && d.thumbnail.source ? d.thumbnail.source : null;\\n      imageCache[ev.id] = src; return src;\\n    }).catch(function(){ imageCache[ev.id]=null; return null; });\\n  }\\n  function paintThumb(el, ev){\\n    el.textContent = initials(ev.title);\\n    loadImage(ev).then(function(src){\\n      if(!src) return;\\n      var img = new Image();\\n      img.alt = '';\\n      img.onload = function(){ el.textContent=''; el.appendChild(img); };\\n      img.src = src;\\n    });\\n  }\\n\\n  // ---- game state -------------------------------------------------------\\n  var state;\\n  function newGame(){\\n    var all = shuffle(puzzle.events);\\n    var chrono = all.slice().sort(byDate);\\n    var anchor = chrono[Math.floor(chrono.length/2)]; // chronologically middle\\n    var queue = shuffle(all.filter(function(e){ return e.id !== anchor.id; }));\\n    state = {\\n      placed: [Object.assign({}, anchor, {status:'anchor'})],\\n      queue: queue,\\n      total: queue.length,\\n      sel: null,\\n      score: 0,\\n      streak: 0,\\n      correct: 0,\\n      done: 0,\\n      locked: false,\\n      justId: null,\\n      wrongReveal: null,\\n      wrongPhase: false,\\n      animateJust: false,\\n      mode: loadMode()\\n    };\\n    // warm the cache so thumbnails are ready when a card surfaces\\n    puzzle.events.forEach(loadImage);\\n    applyModeUI();\\n    render();\\n  }\\n\\n  function correctIndex(ev){\\n    var i = 0;\\n    while (i < state.placed.length && state.placed[i].date < ev.date) i++;\\n    return i;\\n  }\\n\\n  // ---- rendering --------------------------------------------------------\\n  function cardHtml(ev, cls){\\n    var dateLine = ev.status==='hidden' ? '' :\\n      '<div class=\\\"cd\\\">'+esc(ev.displayDate)+'</div>';\\n    var badge = '';\\n    if (ev.status==='anchor') badge='<span class=\\\"badge\\\">Anchor</span>';\\n    else if (ev.id===state.justId){ if(ev.status==='correct') badge='<span class=\\\"badge\\\">correct</span>'; else if(state.wrongPhase) badge='<span class=\\\"badge\\\" style=\\\"color:var(--bad);border-color:var(--bad)\\\">wrong</span>'; else badge='<span class=\\\"badge\\\">actually here</span>'; }\\n    return '<div class=\\\"card '+cls+'\\\" data-ev=\\\"'+esc(ev.id)+'\\\">'+\\n      '<span class=\\\"dot\\\"></span>'+\\n      '<span class=\\\"thumb\\\" data-thumb=\\\"'+esc(ev.id)+'\\\"></span>'+\\n      '<div class=\\\"body\\\"><p class=\\\"ct\\\">'+esc(ev.title)+'</p>'+dateLine+'</div>'+\\n      badge+'</div>';\\n  }\\n\\n  // Mode-specific instruction shown above the Commit button.\\n  function pickHint(){\\n    if (state.sel !== null) return 'Gap selected — press <b>Enter</b> or click Commit';\\n    if (state.mode==='drag') return 'Drag this card onto a gap ↑, then press <b>Enter</b> or Commit';\\n    if (state.mode==='keyboard') return 'Press <b>↑ / ↓</b> to choose a gap, then <b>Enter</b> or Commit';\\n    return 'Tap a marked gap on the timeline ↑, then press <b>Enter</b> or Commit';\\n  }\\n\\n  function render(){\\n    if (state.queue.length===0 && !state.current){ return renderResults(); }\\n    if (!state.current) state.current = state.queue.shift();\\n    state.placed.sort(byDate);\\n\\n    // During the wrong-reveal phase, temporarily show the card at the player's\\n    // chosen (wrong) slot so the correction is visually obvious.\\n    var displayPlaced = state.placed;\\n    if (state.wrongReveal) {\\n      var wr = state.wrongReveal;\\n      displayPlaced = state.placed.filter(function(e){ return e.id !== wr.ev.id; });\\n      displayPlaced.splice(wr.slot, 0, wr.ev);\\n    }\\n\\n    elSub.textContent = (state.done+1)+' of '+(state.total)+' to place';\\n    elBar.style.width = Math.round((state.done/state.total)*100)+'%';\\n\\n    var html = '<div class=\\\"timeline'+(state.locked?' locked':'')+'\\\" id=\\\"tl\\\">';\\n    html += '<div class=\\\"axis-cap top\\\"><span class=\\\"cap-arrow\\\" aria-hidden=\\\"true\\\">↑</span>Earlier in time</div>';\\n    for (var i=0;i<=displayPlaced.length;i++){\\n      html += '<div class=\\\"slot'+(state.sel===i?' sel':'')+'\\\" data-slot=\\\"'+i+'\\\" role=\\\"button\\\" tabindex=\\\"0\\\" aria-label=\\\"Place event in position '+(i+1)+' of '+(displayPlaced.length+1)+'\\\"></div>';\\n      if (i < displayPlaced.length){\\n        var ev = displayPlaced[i];\\n        var cls = (ev.status||'') + (ev.id===state.justId?' just':'') + (ev.id===state.justId&&state.animateJust?' popping':'');\\n        html += cardHtml(ev, cls.trim());\\n      }\\n    }\\n    html += '<div class=\\\"axis-cap bottom\\\"><span class=\\\"cap-arrow\\\" aria-hidden=\\\"true\\\">↓</span>Later in time</div>';\\n    html += '</div>';\\n\\n    var cur = state.current;\\n    html += '<div class=\\\"tray\\\"><div class=\\\"tray-inner\\\">'+\\n      '<div class=\\\"deal\\\" id=\\\"deal\\\">'+\\n        '<span class=\\\"thumb\\\" data-thumb=\\\"'+esc(cur.id)+'\\\"></span>'+\\n        '<div class=\\\"body\\\"><div class=\\\"hint\\\">Where does this go?</div>'+\\n          '<h2>'+esc(cur.title)+'</h2><p>'+esc(cur.summary)+'</p></div>'+\\n      '</div>'+\\n      '<div class=\\\"commit\\\">'+\\n        '<div class=\\\"pick\\\" id=\\\"pick\\\">'+pickHint()+'</div>'+\\n        '<button class=\\\"btn primary\\\" id=\\\"commit\\\"'+(state.sel===null?' disabled':'')+'>Commit</button>'+\\n      '</div>'+\\n    '</div></div>';\\n\\n    board.innerHTML = html;\\n    // thumbnails\\n    board.querySelectorAll('[data-thumb]').forEach(function(el){\\n      var id = el.getAttribute('data-thumb');\\n      var ev = (id===cur.id) ? cur : state.placed.filter(function(e){return e.id===id;})[0];\\n      if (ev) paintThumb(el, ev);\\n    });\\n    wire();\\n  }\\n\\n  function wire(){\\n    board.querySelectorAll('.slot').forEach(function(s){\\n      var idx = parseInt(s.getAttribute('data-slot'),10);\\n      var choose = function(){ if(state.locked) return; state.sel = idx; render(); };\\n      s.addEventListener('click', choose);\\n      s.addEventListener('keydown', function(e){ if(e.key==='Enter'||e.key===' '){ e.preventDefault(); choose(); } });\\n      if (state.mode==='drag'){\\n        s.addEventListener('dragenter', function(e){ if(state.locked) return; e.preventDefault(); s.classList.add('drop'); });\\n        s.addEventListener('dragover', function(e){ if(state.locked) return; e.preventDefault(); if(e.dataTransfer) e.dataTransfer.dropEffect='move'; s.classList.add('drop'); });\\n        s.addEventListener('dragleave', function(){ s.classList.remove('drop'); });\\n        s.addEventListener('drop', function(e){ if(state.locked) return; e.preventDefault(); s.classList.remove('drop'); state.sel = idx; render(); });\\n      }\\n    });\\n    var c = document.getElementById('commit');\\n    if (c) c.addEventListener('click', commit);\\n    if (state.mode==='drag'){\\n      var deal = document.getElementById('deal');\\n      if (deal){\\n        deal.setAttribute('draggable','true');\\n        deal.addEventListener('dragstart', function(e){\\n          if(state.locked){ e.preventDefault(); return; }\\n          document.body.classList.add('dragging');\\n          if(e.dataTransfer){ e.dataTransfer.effectAllowed='move'; try{ e.dataTransfer.setData('text/plain', String(state.current && state.current.id)); }catch(_){} }\\n        });\\n        deal.addEventListener('dragend', function(){\\n          document.body.classList.remove('dragging');\\n          board.querySelectorAll('.slot.drop').forEach(function(x){ x.classList.remove('drop'); });\\n        });\\n      }\\n    }\\n  }\\n\\n  function commit(){\\n    if (state.locked || state.sel===null) return;\\n    state.locked = true;\\n    var cur = state.current;\\n    var want = correctIndex(cur);\\n    var ok = state.sel === want;\\n    var wrongSlot = state.sel;\\n\\n    var gained = 0;\\n    if (ok){ gained = POINTS + STREAK_BONUS*state.streak; state.streak++; state.correct++; }\\n    else { state.streak = 0; }\\n    state.score += gained;\\n\\n    // Always insert at the correct chronological position; a wrong guess snaps\\n    // to where it belongs after a brief reveal at the player's chosen slot.\\n    cur.status = ok ? 'correct' : 'wrong';\\n    state.placed.push(cur);\\n    state.placed.sort(byDate);\\n    state.justId = cur.id;\\n    state.done++;\\n    state.sel = null;\\n    state.current = null;\\n\\n    updateStats(gained, ok);\\n\\n    if (!ok) {\\n      // Phase 1: show the card at the player's (wrong) slot with a red badge.\\n      state.wrongReveal = { slot: wrongSlot, ev: cur };\\n      state.wrongPhase = true;\\n      state.animateJust = false;\\n      render();\\n      setTimeout(function(){\\n        // Phase 2: snap the card to its correct position with the pop animation.\\n        state.wrongReveal = null;\\n        state.wrongPhase = false;\\n        state.animateJust = true;\\n        render();\\n        state.animateJust = false;\\n        setTimeout(function(){ state.locked = false; render(); }, 400);\\n      }, 700);\\n    } else {\\n      state.animateJust = true;\\n      render();\\n      state.animateJust = false;\\n      setTimeout(function(){ state.locked = false; render(); }, 500);\\n    }\\n  }\\n\\n  function updateStats(gained, ok){\\n    elScore.textContent = state.score;\\n    elStreak.textContent = state.streak;\\n    if (state.streak>0) elStreakBox.classList.remove('cold'); else elStreakBox.classList.add('cold');\\n    if (gained>0) floatText('+'+gained, 'var(--good)');\\n    else floatText(ok?'+0':'missed', 'var(--bad)');\\n  }\\n\\n  function floatText(txt, color){\\n    var f = document.createElement('div');\\n    f.className='float'; f.textContent=txt; f.style.color=color; f.style.top='64px'; f.style.fontSize='1.3rem';\\n    document.body.appendChild(f);\\n    setTimeout(function(){ f.remove(); }, 1000);\\n  }\\n\\n  // ---- results ----------------------------------------------------------\\n  function renderResults(){\\n    elBar.style.width='100%';\\n    elSub.textContent='Complete';\\n    var chrono = state.placed.slice().sort(byDate);\\n    var acc = state.correct + ' / ' + state.total;\\n    var pct = Math.round((state.correct/state.total)*100);\\n    var grade = pct===100?'Perfect!':pct>=80?'Sharp eye':pct>=50?'Not bad':'Keep going';\\n\\n    var rows = chrono.map(function(ev){\\n      var mk = ev.status==='wrong' ? '✕' : '✓';\\n      var col = ev.status==='wrong' ? 'var(--bad)' : (ev.status==='anchor'?'#000':'var(--good)');\\n      return '<div class=\\\"resrow\\\">'+\\n        '<span class=\\\"mk\\\" style=\\\"color:'+col+'\\\">'+mk+'</span>'+\\n        '<div class=\\\"rt\\\"><div class=\\\"n\\\">'+esc(ev.title)+'</div><div class=\\\"d\\\">'+esc(ev.displayDate)+'</div></div>'+\\n        '<a href=\\\"'+esc(ev.wikipediaUrl)+'\\\" target=\\\"_blank\\\" rel=\\\"noopener\\\">Dive deeper ↗</a>'+\\n      '</div>';\\n    }).join('');\\n\\n    board.innerHTML =\\n      '<div class=\\\"results\\\">'+\\n        '<div class=\\\"restitle\\\">'+esc(puzzle.theme||'Results')+'</div>'+\\n        '<div class=\\\"grade\\\">'+esc(grade)+'</div>'+\\n        '<div class=\\\"acc\\\">You placed <b>'+acc+'</b> correctly · <b>'+state.score+'</b> points</div>'+\\n      '</div>'+\\n      '<div class=\\\"reslist\\\">'+rows+'</div>'+\\n      '<div class=\\\"actions\\\">'+\\n        '<button class=\\\"btn primary\\\" id=\\\"again\\\">Play again</button>'+\\n        '<a class=\\\"btn\\\" href=\\\"/\\\">More puzzles</a>'+\\n      '</div>';\\n    var a = document.getElementById('again');\\n    if (a) a.addEventListener('click', function(){ newGame(); window.scrollTo(0,0); });\\n  }\\n\\n  // Mode switcher — wired once; it persists across re-renders and replays.\\n  if (modesEl) modesEl.querySelectorAll('.modebtn').forEach(function(b){\\n    b.addEventListener('click', function(){ setMode(b.getAttribute('data-mode')); });\\n  });\\n\\n  // Global keyboard handler — Enter commits a selected gap in any mode;\\n  // ↑/↓ navigate between gaps in keyboard mode.\\n  document.addEventListener('keydown', function(e){\\n    if (state.locked || !state.current) return;\\n    if (e.key==='Enter' && state.sel!==null){ e.preventDefault(); commit(); return; }\\n    if (state.mode!=='keyboard') return;\\n    var max = state.placed.length; // gaps are indexed 0..placed.length\\n    if (e.key==='ArrowDown' || e.key==='ArrowUp'){\\n      e.preventDefault();\\n      if (state.sel===null) state.sel = e.key==='ArrowDown' ? 0 : max;\\n      else { state.sel += e.key==='ArrowDown' ? 1 : -1; state.sel = Math.max(0, Math.min(max, state.sel)); }\\n      render(); scrollSelIntoView();\\n    }\\n  });\\n\\n  newGame();\\n})();\\n`;\\n\"}"}]}
